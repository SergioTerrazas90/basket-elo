@using System.Security.Claims
@using BasketElo.Infrastructure.Identity
@using Microsoft.Extensions.Options
@inject IOptions<AuthOptions> AuthOptions

@if (AuthOptions.Value.Enabled)
{
    <AuthorizeView>
        <Authorized>
            <div class="auth-status">
                <span>@DisplayName(context.User)</span>
                <a href="auth/logout">Sign out</a>
            </div>
        </Authorized>
        <NotAuthorized>
            <a class="auth-sign-in" href="auth/login">Sign in</a>
        </NotAuthorized>
    </AuthorizeView>
}

@code {
    private static string DisplayName(ClaimsPrincipal user)
        => user.FindFirstValue(ClaimTypes.Name)
            ?? user.FindFirstValue(ClaimTypes.Email)
            ?? "Signed in";
}
