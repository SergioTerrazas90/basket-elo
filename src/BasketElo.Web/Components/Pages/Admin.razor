@page "/admin"
@attribute [Authorize(Roles = "admin")]
@rendermode InteractiveServer
@using BasketElo.Domain.Admin
@using BasketElo.Domain.Elo
@using BasketElo.Domain.Entities
@using BasketElo.Web.Elo
@inject HttpClient Http
@inject EloRebuildNotificationCenter Notifications
@implements IDisposable

<PageTitle>Internal Admin</PageTitle>

<div class="admin-page">
    <section class="page-header">
        <div>
            <p class="eyebrow">Internal Admin</p>
            <h1>Pipeline operations</h1>
            <p class="intro">Monitor ingestion, data health, system status, and ELO rebuilds from one internal surface.</p>
        </div>
        <button class="btn btn-outline-primary" @onclick="() => RefreshAsync()" disabled="@isBusy">Refresh</button>
    </section>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="alert @messageCss" role="alert">
            @message
        </div>
    }

    @if (adminDashboard is null && isBusy)
    {
        <p>Loading admin dashboard...</p>
    }
    else if (adminDashboard is not null)
    {
        <section class="summary-panel">
            <div class="summary-card accent-card">
                <span class="summary-label">Selected Ruleset</span>
                <strong>@adminDashboard.Elo.Summary.SelectedRuleset</strong>
            </div>
            <div class="summary-card">
                <span class="summary-label">Completed Games</span>
                <strong>@adminDashboard.DataHealth.CompletedGames</strong>
            </div>
            <div class="summary-card @(adminDashboard.DataHealth.UnratedCompletedGames > 0 ? "warning-card" : null)">
                <span class="summary-label">Unrated Completed Games</span>
                <strong>@adminDashboard.DataHealth.UnratedCompletedGames</strong>
            </div>
            <div class="summary-card">
                <span class="summary-label">Rated Teams</span>
                <strong>@adminDashboard.Elo.Summary.RatedTeams</strong>
            </div>
            <div class="summary-card">
                <span class="summary-label">DB Status</span>
                <strong>@(adminDashboard.System.DatabaseCanConnect ? "Connected" : "Offline")</strong>
            </div>
            <div class="summary-card">
                <span class="summary-label">Worker Status</span>
                <strong>@FormatStatus(adminDashboard.System.WorkerStatus)</strong>
            </div>
        </section>

        <section class="panel-grid">
            <section class="control-panel">
                <div class="section-head">
                    <h2>ELO rebuilds</h2>
                    <p>Queue a full rebuild for one ruleset. The default public ruleset is selected first.</p>
                </div>

                <div class="control-row">
                    <div class="filter-field">
                        <label for="rulesetSelect">Ruleset</label>
                        <select id="rulesetSelect" class="form-select" @bind="selectedRuleset">
                            @foreach (var ruleset in adminDashboard.Elo.Rulesets.Rulesets)
                            {
                                <option value="@ruleset">@ruleset</option>
                            }
                        </select>
                    </div>

                    <div class="filter-field compact-action">
                        <label>&nbsp;</label>
                        <button class="btn btn-primary" @onclick="TriggerRebuildAsync" disabled="@(isBusy || HasActiveRebuild)">
                            Trigger rebuild
                        </button>
                    </div>
                </div>

                <p class="hint">API default: <strong>@adminDashboard.Elo.Rulesets.DefaultRuleset</strong>. Latest successful rebuild: <strong>@FormatDate(adminDashboard.DataHealth.LatestSuccessfulRebuildUtc)</strong>.</p>
            </section>

            <section class="control-panel">
                <div class="section-head">
                    <h2>System status</h2>
                    <p>Operational heartbeat from database, migrations, and latest worker-owned job activity.</p>
                </div>

                <dl class="status-list">
                    <div>
                        <dt>Database</dt>
                        <dd>@(adminDashboard.System.DatabaseCanConnect ? "Connected" : "Cannot connect")</dd>
                    </div>
                    <div>
                        <dt>Pending migrations</dt>
                        <dd>@adminDashboard.System.PendingMigrationsCount</dd>
                    </div>
                    <div>
                        <dt>Latest worker activity</dt>
                        <dd>@FormatDate(adminDashboard.System.LatestWorkerActivityUtc)</dd>
                    </div>
                    <div>
                        <dt>Server UTC</dt>
                        <dd>@FormatDate(adminDashboard.System.ServerUtc)</dd>
                    </div>
                </dl>
            </section>
        </section>

        <section class="panel-grid">
            <section class="control-panel">
                <div class="section-head">
                    <h2>Data health</h2>
                    <p>Basic coverage and identity signals that can affect rating trust.</p>
                </div>

                <dl class="status-list">
                    <div>
                        <dt>Teams missing country</dt>
                        <dd>@adminDashboard.DataHealth.TeamsMissingCountry</dd>
                    </div>
                    <div>
                        <dt>Possible duplicate aliases</dt>
                        <dd>@adminDashboard.DataHealth.PossibleDuplicateAliasGroups</dd>
                    </div>
                    <div>
                        <dt>Open identity warnings</dt>
                        <dd>@adminDashboard.DataHealth.OpenIdentityWarnings</dd>
                    </div>
                    <div>
                        <dt>Open identity blockers</dt>
                        <dd>@adminDashboard.DataHealth.OpenIdentityBlockers</dd>
                    </div>
                </dl>

                <div class="link-grid compact-links">
                    <a class="tool-card" href="admin/identity">
                        <span class="tool-label">Identity Health</span>
                        <strong>Review findings</strong>
                    </a>
                    <a class="tool-card" href="backfill">
                        <span class="tool-label">Backfill Coverage</span>
                        <strong>Queue seasons</strong>
                    </a>
                </div>
            </section>

            <section class="table-section compact-table-section">
                <div class="section-head">
                    <h2>Game coverage</h2>
                    <p>Loaded games by competition and season for the selected ruleset.</p>
                </div>

                <div class="table-responsive">
                    <table class="table table-striped align-middle admin-table">
                        <thead>
                            <tr>
                                <th>Competition</th>
                                <th>Season</th>
                                <th>Games</th>
                                <th>Completed</th>
                                <th>Unrated</th>
                                <th>Latest</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (adminDashboard.GameCoverage.Count == 0)
                            {
                                <tr>
                                    <td colspan="6" class="empty-state">No games loaded yet.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var row in adminDashboard.GameCoverage)
                                {
                                    <tr>
                                        <td>@row.Competition</td>
                                        <td>@row.Season</td>
                                        <td>@row.GamesLoaded</td>
                                        <td>@row.CompletedGames</td>
                                        <td class="@(row.UnratedCompletedGames > 0 ? "attention-text" : null)">@row.UnratedCompletedGames</td>
                                        <td>@FormatDate(row.LatestGameUtc)</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        </section>

        <section class="table-section">
            <div class="section-head">
                <h2>Recent backfill jobs</h2>
                <p>Latest ingestion jobs with request usage, warnings, summaries, and errors.</p>
            </div>

            <div class="table-responsive">
                <table class="table table-striped align-middle admin-table">
                    <thead>
                        <tr>
                            <th>Created</th>
                            <th>Provider</th>
                            <th>Country</th>
                            <th>League</th>
                            <th>Season</th>
                            <th>Status</th>
                            <th>Dry Run</th>
                            <th>Requests</th>
                            <th>Warnings</th>
                            <th>Started</th>
                            <th>Finished</th>
                            <th>Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (adminDashboard.RecentBackfillJobs.Count == 0)
                        {
                            <tr>
                                <td colspan="12" class="empty-state">No backfill jobs recorded yet.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var job in adminDashboard.RecentBackfillJobs)
                            {
                                <tr>
                                    <td>@FormatDate(job.CreatedAtUtc)</td>
                                    <td>@job.Provider</td>
                                    <td>@job.Country</td>
                                    <td>@job.LeagueName</td>
                                    <td>@job.Season</td>
                                    <td><span class="status-pill @StatusClass(job.Status)">@FormatStatus(job.Status)</span></td>
                                    <td>@(job.DryRun ? "Yes" : "No")</td>
                                    <td>@job.RequestsUsed</td>
                                    <td>@job.WarningCount</td>
                                    <td>@FormatDate(job.StartedAtUtc)</td>
                                    <td>@FormatDate(job.FinishedAtUtc)</td>
                                    <td>@Details(job.SummaryJson, job.ErrorMessage)</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="table-section">
            <div class="section-head">
                <h2>Recent rebuild runs</h2>
                <p>Latest rebuild history across rulesets with worker actions.</p>
            </div>

            <div class="table-responsive">
                <table class="table table-striped align-middle admin-table">
                    <thead>
                        <tr>
                            <th>Queued</th>
                            <th>Started</th>
                            <th>Ruleset</th>
                            <th>Status</th>
                            <th>Finished</th>
                            <th>Games</th>
                            <th>Teams</th>
                            <th>From Game</th>
                            <th>Notes</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (adminDashboard.Elo.RecentRuns.Count == 0)
                        {
                            <tr>
                                <td colspan="10" class="empty-state">No rebuild runs recorded yet.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var run in adminDashboard.Elo.RecentRuns)
                            {
                                <tr>
                                    <td>@FormatDate(run.QueuedAtUtc)</td>
                                    <td>@FormatDate(run.StartedAtUtc)</td>
                                    <td>@run.RulesetVersion</td>
                                    <td><span class="status-pill @StatusClass(run.Status)">@FormatStatus(run.Status)</span></td>
                                    <td>@FormatDate(run.FinishedAtUtc)</td>
                                    <td>@run.GamesProcessed</td>
                                    <td>@run.TeamsRated</td>
                                    <td>@FormatDate(run.FromGameDateTimeUtc)</td>
                                    <td>@Details(run.Notes, null)</td>
                                    <td>
                                        <div class="row-actions">
                                            @if (run.Status == EloRebuildRunStatus.Pending)
                                            {
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => CancelRebuildAsync(run.Id)" disabled="@isBusy">
                                                    Cancel
                                                </button>
                                            }
                                            @if (run.Status == EloRebuildRunStatus.Failed || run.Status == EloRebuildRunStatus.Canceled)
                                            {
                                                <button class="btn btn-sm btn-outline-primary" @onclick="() => RetryRebuildAsync(run.Id)" disabled="@isBusy">
                                                    Retry
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }
</div>

@code {
    private AdminDashboardResponse? adminDashboard;
    private string? selectedRuleset;
    private bool isBusy;
    private string? message;
    private string messageCss = "alert-info";
    private IDisposable? notificationSubscription;

    protected override async Task OnInitializedAsync()
    {
        notificationSubscription = Notifications.Subscribe(HandleRebuildNotificationAsync);
        await RefreshAsync();
    }

    private async Task RefreshAsync(bool clearMessage = true)
    {
        isBusy = true;
        if (clearMessage)
        {
            message = null;
        }

        try
        {
            adminDashboard = await Http.GetFromJsonAsync<AdminDashboardResponse>(BuildDashboardUri());
            if (adminDashboard is not null)
            {
                selectedRuleset ??= adminDashboard.Elo.Summary.SelectedRuleset;
            }
        }
        catch (Exception ex)
        {
            message = $"Could not load admin dashboard: {ex.Message}";
            messageCss = "alert-danger";
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task TriggerRebuildAsync()
    {
        if (string.IsNullOrWhiteSpace(selectedRuleset))
        {
            message = "Choose a ruleset before triggering a rebuild.";
            messageCss = "alert-warning";
            return;
        }

        isBusy = true;
        message = null;

        try
        {
            var response = await Http.PostAsJsonAsync(
                "api/elo/rebuilds",
                new EloRebuildRequest { RulesetVersion = selectedRuleset });

            if (!response.IsSuccessStatusCode)
            {
                throw new InvalidOperationException(await ReadErrorAsync(response));
            }

            var results = await response.Content.ReadFromJsonAsync<IReadOnlyList<EloRebuildRunDto>>() ?? [];
            var triggered = results.FirstOrDefault();
            message = triggered is null
                ? $"Rebuild requested for {selectedRuleset}. This page will update when the worker finishes."
                : $"Rebuild queued for {triggered.RulesetVersion}. This page will update when the worker finishes.";
            messageCss = "alert-success";
            await RefreshAsync(clearMessage: false);
        }
        catch (Exception ex)
        {
            message = $"Rebuild failed: {ex.Message}";
            messageCss = "alert-danger";
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task CancelRebuildAsync(Guid runId)
    {
        await RunRebuildActionAsync(
            () => Http.PostAsync($"api/elo/rebuilds/{runId}/cancel", null),
            "Rebuild canceled.");
    }

    private async Task RetryRebuildAsync(Guid runId)
    {
        await RunRebuildActionAsync(
            () => Http.PostAsync($"api/elo/rebuilds/{runId}/retry", null),
            "Retry queued. This page will update when the worker finishes.");
    }

    private async Task RunRebuildActionAsync(Func<Task<HttpResponseMessage>> action, string successMessage)
    {
        isBusy = true;
        message = null;

        try
        {
            using var response = await action();
            if (!response.IsSuccessStatusCode)
            {
                throw new InvalidOperationException(await ReadErrorAsync(response));
            }

            message = successMessage;
            messageCss = "alert-success";
            await RefreshAsync(clearMessage: false);
        }
        catch (Exception ex)
        {
            message = $"Rebuild action failed: {ex.Message}";
            messageCss = "alert-danger";
        }
        finally
        {
            isBusy = false;
        }
    }

    private string BuildDashboardUri()
    {
        var ruleset = string.IsNullOrWhiteSpace(selectedRuleset) ? null : selectedRuleset;
        return string.IsNullOrWhiteSpace(ruleset)
            ? "api/admin/dashboard"
            : $"api/admin/dashboard?rulesetVersion={Uri.EscapeDataString(ruleset)}";
    }

    private static async Task<string> ReadErrorAsync(HttpResponseMessage response)
    {
        var body = await response.Content.ReadAsStringAsync();
        return string.IsNullOrWhiteSpace(body) ? response.ReasonPhrase ?? "Request failed." : body;
    }

    private static string FormatDate(DateTime? value) => value?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "-";

    private static string FormatStatus(string status) => status.Replace('_', ' ');

    private static string StatusClass(string status) => status switch
    {
        "completed" => "status-completed",
        "completed_with_warnings" => "status-warning",
        "dry_run" => "status-dry-run",
        "no_data" => "status-empty",
        "partial" => "status-partial",
        "pending" => "status-progress",
        "running" => "status-progress",
        "canceled" => "status-canceled",
        "failed" => "status-failed",
        "attention" => "status-failed",
        "idle" => "status-empty",
        _ => "status-empty"
    };

    private static RenderFragment Details(string? summary, string? error) => builder =>
    {
        var text = string.IsNullOrWhiteSpace(error) ? summary : error;
        if (string.IsNullOrWhiteSpace(text))
        {
            builder.AddContent(0, "-");
            return;
        }

        builder.OpenElement(1, "details");
        builder.AddAttribute(2, "class", "notes-details");
        builder.OpenElement(3, "summary");
        builder.AddContent(4, string.IsNullOrWhiteSpace(error) ? "View" : "Error");
        builder.CloseElement();
        builder.OpenElement(5, "pre");
        builder.AddContent(6, text);
        builder.CloseElement();
        builder.CloseElement();
    };

    private bool HasActiveRebuild => adminDashboard?.Elo.RecentRuns.Any(x =>
        x.RulesetVersion == selectedRuleset &&
        (x.Status == EloRebuildRunStatus.Pending || x.Status == EloRebuildRunStatus.Running)) == true;

    private Task HandleRebuildNotificationAsync(EloRebuildRunNotification notification)
    {
        return InvokeAsync(async () =>
        {
            if (!IsRelevantNotification(notification))
            {
                return;
            }

            message = $"Rebuild {notification.Status} for {notification.RulesetVersion}. Dashboard refreshed.";
            messageCss = notification.Status == EloRebuildRunStatus.Failed ? "alert-danger" : "alert-success";
            await RefreshAsync(clearMessage: false);
            StateHasChanged();
        });
    }

    private bool IsRelevantNotification(EloRebuildRunNotification notification)
    {
        return string.Equals(notification.RulesetVersion, selectedRuleset, StringComparison.OrdinalIgnoreCase) ||
            adminDashboard?.Elo.RecentRuns.Any(x => x.Id == notification.RunId) == true;
    }

    public void Dispose()
    {
        notificationSubscription?.Dispose();
    }
}
