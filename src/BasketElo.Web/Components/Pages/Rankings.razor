    private void RebuildEvolutionChartSeries(bool resetViewport = true)
    {
        var visibleTeamIds = evolutionRankings?.Rankings
            .Select(row => row.TeamId)
            .ToHashSet() ?? [];
        var refinedSeriesByTeam = EvolutionSeries
            .ToDictionary(series => series.TeamId);
        var baseSeries = (fullEvolution ?? evolution)?.Series
            .Where(series => visibleTeamIds.Contains(series.TeamId))
            .ToList() ?? [];
        if (resetViewport)
        {
            evolutionVisibleRatedPointCounts.Clear();
            foreach (var series in baseSeries)
            {
                evolutionVisibleRatedPointCounts[series.TeamId] = series.RatedPointCount;
            }
        }

        evolutionChartSeries = baseSeries
            .Select((series, index) =>
            {
                var color = ChartColor(index);
                var points = ToChartPoints(series.Points, series.TeamName, color);
                if (refinedSeriesByTeam.TryGetValue(series.TeamId, out var refined))
                {
                    points = EloChartData.MergePoints(
                        points,
                        ToChartPoints(refined.Points, refined.TeamName, color));
                }

                var ratedPointCount = series.RatedPointCount > 0
                    ? series.RatedPointCount
                    : points.Count;
                var visibleRatedPointCount = evolutionVisibleRatedPointCounts.TryGetValue(series.TeamId, out var visibleCount)
                    ? visibleCount
                    : ratedPointCount;
                return new EloChartSeries(
                    series.TeamId,
                    series.TeamName,
                    color,
                    points,
                    ratedPointCount,
                    visibleRatedPointCount);
            })
            .ToList();
        if (resetViewport)
        {
            evolutionDataRevision++;
        }
    }

    private static IReadOnlyList<EloChartPoint> ToChartPoints(
        IReadOnlyCollection<EloTeamEvolutionPoint> points,
        string teamName,
        string color)
        => points
            .OrderBy(point => point.GameDateTimeUtc)
            .Select(point => new EloChartPoint(
                        point.GameDateTimeUtc,
                        point.Elo,
                        teamName,
                        color))
            .ToList();

    private static EloRankingsEvolutionResponse MergeEvolutionData(
        EloRankingsEvolutionResponse? baseEvolution,
        EloRankingsEvolutionResponse refinedEvolution)
    {
        if (baseEvolution is null)
        {
            return refinedEvolution;
        }

        var refinedByTeam = refinedEvolution.Series
            .ToDictionary(series => series.TeamId);
        var mergedSeries = baseEvolution.Series
            .Select(series => refinedByTeam.TryGetValue(series.TeamId, out var refined)
                ? series with { Points = MergeEvolutionPoints(series.Points, refined.Points) }
                : series)
            .ToList();

        return baseEvolution with { Series = mergedSeries };
    }

    private static IReadOnlyList<EloTeamEvolutionPoint> MergeEvolutionPoints(
        IReadOnlyCollection<EloTeamEvolutionPoint> basePoints,
        IReadOnlyCollection<EloTeamEvolutionPoint> refinedPoints)
    {
        var refinedDates = refinedPoints
            .Select(point => point.GameDateTimeUtc)
            .ToHashSet();

        return basePoints
            .Where(point => !refinedDates.Contains(point.GameDateTimeUtc))
            .Concat(refinedPoints)
            .OrderBy(point => point.GameDateTimeUtc)
            .ToList();
    }

