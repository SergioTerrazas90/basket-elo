@code {
    [Parameter]
    public EloChartPoint? Point { get; set; }

    [Parameter]
    public EventCallback<EloChartPoint?> ActivePointChanged { get; set; }

    private EloChartPoint? announcedPoint;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!ActivePointChanged.HasDelegate || ReferenceEquals(Point, announcedPoint))
        {
            return;
        }

        announcedPoint = Point;
        await ActivePointChanged.InvokeAsync(Point);
    }
}
