@using System.Security.Claims
@using BasketElo.Infrastructure.Identity
@using BasketElo.Web.Auth
@using Microsoft.Extensions.Options
@inject IOptions<AuthOptions> AuthOptions
@inject NavigationManager Navigation

@if (AuthOptions.Value.Enabled)
{
    <AuthorizeView>
        <Authorized>
            <div class="auth-status">
                <span>@DisplayName(context.User)</span>
                <a href="auth/logout">Sign out</a>
            </div>
        </Authorized>
        <NotAuthorized>
            <a class="auth-sign-in" href="auth/login">Sign in</a>
        </NotAuthorized>
    </AuthorizeView>
}
else
{
    <AuthorizeView>
        <Authorized>
            <div class="dev-persona-switch">
                <label for="devPersona">Testing as</label>
                <select id="devPersona" class="dev-persona-select" value="@CurrentPersona(context.User)" @onchange="ChangePersona">
                    <option value="anonymous">Anonymous</option>
                    <option value="free">Free</option>
                    <option value="paid">Paying</option>
                    <option value="admin">Admin</option>
                </select>
            </div>
        </Authorized>
        <NotAuthorized>
            <div class="dev-persona-switch">
                <label for="devPersona">Testing as</label>
                <select id="devPersona" class="dev-persona-select" value="anonymous" @onchange="ChangePersona">
                    <option value="anonymous">Anonymous</option>
                    <option value="free">Free</option>
                    <option value="paid">Paying</option>
                    <option value="admin">Admin</option>
                </select>
            </div>
        </NotAuthorized>
    </AuthorizeView>
}

@code {
    private static string DisplayName(ClaimsPrincipal user)
        => user.FindFirstValue(ClaimTypes.Name)
            ?? user.FindFirstValue(ClaimTypes.Email)
            ?? "Signed in";

    private static string CurrentPersona(ClaimsPrincipal user)
    {
        var email = user.FindFirstValue(ClaimTypes.Email);
        if (string.Equals(email, "dev-free@basket-elo.local", StringComparison.OrdinalIgnoreCase))
        {
            return "free";
        }

        if (string.Equals(email, "dev-paid@basket-elo.local", StringComparison.OrdinalIgnoreCase))
        {
            return "paid";
        }

        return user.IsInRole("admin") ? "admin" : "anonymous";
    }

    private void ChangePersona(ChangeEventArgs args)
    {
        var persona = args.Value?.ToString() ?? "anonymous";
        var currentUri = new Uri(Navigation.Uri);
        var returnUrl = currentUri.PathAndQuery;
        Navigation.NavigateTo(
            $"dev/persona?persona={Uri.EscapeDataString(persona)}&returnUrl={Uri.EscapeDataString(returnUrl)}",
            forceLoad: true);
    }
}
