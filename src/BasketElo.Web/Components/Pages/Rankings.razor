    private async Task<EloRankingsEvolutionResponse?> FetchEvolutionAsync()
    {
        if (evolutionRankings is null || evolutionRankings.Rankings.Count == 0)
        {
            return null;
        }

        var evolutionUri = BuildEvolutionApiUri();
        if (fullEvolution is not null && string.Equals(evolutionUri, lastEvolutionApiUri, StringComparison.Ordinal))
        {
            return fullEvolution;
        }

        var result = await Http.GetFromJsonAsync<EloRankingsEvolutionResponse>(evolutionUri);
        lastEvolutionApiUri = evolutionUri;
        return result;
