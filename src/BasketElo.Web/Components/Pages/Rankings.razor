    private string BuildEvolutionApiUri(DateTime? viewportFromUtc = null, DateTime? viewportToUtc = null)
    {
        var seasonRange = GetSelectedSeasonDateRange();
        var teamIds = string.Join(",", evolutionRankings?.Rankings.Take(20).Select(x => x.TeamId) ?? []);
        var query = new List<string>
        {
            $"rulesetVersion={Uri.EscapeDataString(response?.RulesetVersion ?? string.Empty)}",
            $"pool={Uri.EscapeDataString(selectedPool)}",
            $"teamIds={Uri.EscapeDataString(teamIds)}",
            $"pointsPerTeam={EloEvolutionLimits.DefaultPointsPerTeam}"
        };

        Append(query, "fromUtc", (viewportFromUtc ?? seasonRange.FromUtc)?.ToString("O"));
        Append(query, "toUtc", (viewportToUtc ?? seasonRange.ToUtc)?.ToString("O"));
        Append(query, "competition", selectedCompetition);

        return $"api/elo/rankings/evolution?{string.Join("&", query)}";
    }

    private Task QueueEvolutionRefinementAsync(EloChartViewportRange range)
    {
        CancelEvolutionRefinement();
        var cancellation = new CancellationTokenSource();
        evolutionRefinementCancellation = cancellation;
        isEvolutionRefining = true;
        _ = RefineEvolutionAsync(range, cancellation);
        return Task.CompletedTask;
    }

    private async Task RefineEvolutionAsync(EloChartViewportRange range, CancellationTokenSource cancellation)
    {
        try
        {
            await Task.Delay(EvolutionRefinementDebounceMilliseconds, cancellation.Token);
            var fromUtc = DateTime.SpecifyKind(range.FromUtc.Date, DateTimeKind.Utc);
            var toUtc = DateTime.SpecifyKind(range.ToUtc.Date, DateTimeKind.Utc);
            var evolutionUri = BuildEvolutionApiUri(fromUtc, toUtc);

            if (!evolutionRangeCache.TryGetValue(evolutionUri, out var refinedEvolution))
            {
                refinedEvolution = await Http.GetFromJsonAsync<EloRankingsEvolutionResponse>(evolutionUri, cancellation.Token);
                if (refinedEvolution is null)
                {
                    return;
                }

                AddEvolutionRangeToCache(evolutionUri, refinedEvolution);
            }

            cancellation.Token.ThrowIfCancellationRequested();
            if (!ReferenceEquals(evolutionRefinementCancellation, cancellation))
            {
                return;
            }

            evolution = MergeEvolutionData(evolution ?? fullEvolution, refinedEvolution);
            foreach (var series in refinedEvolution.Series)
            {
                evolutionVisibleRatedPointCounts[series.TeamId] = series.RatedPointCount;
            }
            RebuildEvolutionChartSeries(resetViewport: false);
            CaptureActiveRankingsCacheEntry();
            errorMessage = null;
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException) when (cancellation.IsCancellationRequested)
        {
        }
        catch (Exception ex)
        {
            if (ReferenceEquals(evolutionRefinementCancellation, cancellation))
            {
                errorMessage = $"Could not refine chart detail: {ex.Message}";
                await InvokeAsync(StateHasChanged);
            }
        }
        finally
        {
            if (ReferenceEquals(evolutionRefinementCancellation, cancellation))
            {
                evolutionRefinementCancellation = null;
                isEvolutionRefining = false;
                await InvokeAsync(StateHasChanged);
            }

            cancellation.Dispose();
        }
    }

    private Task RestoreFullEvolutionAsync()
    {
        CancelEvolutionRefinement();
        evolutionVisibleRatedPointCounts.Clear();
        foreach (var series in fullEvolution?.Series ?? [])
        {
            evolutionVisibleRatedPointCounts[series.TeamId] = series.RatedPointCount;
        }

        evolutionChartSeries = evolutionChartSeries
            .Select(series => series with { VisibleRatedPointCount = series.RatedPointCount })
            .ToList();
        CaptureActiveRankingsCacheEntry();
        return Task.CompletedTask;
    }

    private void AddEvolutionRangeToCache(string uri, EloRankingsEvolutionResponse response)
    {
        if (evolutionRangeCache.ContainsKey(uri))
        {
            return;
        }

        evolutionRangeCache[uri] = response;
        evolutionRangeCacheOrder.Enqueue(uri);
        while (evolutionRangeCacheOrder.Count > EvolutionRangeCacheLimit)
        {
            evolutionRangeCache.Remove(evolutionRangeCacheOrder.Dequeue());
        }
    }

    private void CancelEvolutionRefinement()
    {
        var cancellation = evolutionRefinementCancellation;
        evolutionRefinementCancellation = null;
        cancellation?.Cancel();
        isEvolutionRefining = false;
    }

    private async Task<EloRankingsResponse?> FetchEvolutionRankingsAsync()
    {
        if (response is null || response.TotalCount == 0)
        {
            return null;
        }

        if (response.Page == 1 && response.Rankings.Count >= Math.Min(20, response.TotalCount))
        {
            return response;
        }

        var evolutionRankingsUri = BuildEvolutionRankingsApiUri();
        if (evolutionRankings is not null && string.Equals(evolutionRankingsUri, lastEvolutionRankingsApiUri, StringComparison.Ordinal))
        {
            return evolutionRankings;
        }

        var result = await Http.GetFromJsonAsync<EloRankingsResponse>(evolutionRankingsUri);
        lastEvolutionRankingsApiUri = evolutionRankingsUri;
        return result;
    }

