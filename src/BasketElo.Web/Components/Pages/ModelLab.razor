            "free" => $"Free users can run and save Model Lab work for {entitlement.RequiredLeagueName ?? "ACB"} only, with 1 stored run.",
            "paid" => $"Paid users can run single, selected, or all-competition backtests and store up to {entitlement.StoredRunLimit ?? 100} runs.",
            _ => string.IsNullOrWhiteSpace(entitlement?.RequiredLeagueName)
                ? "Paid users can run single, selected, or all-competition backtests across all available competitions."
                : $"Current plan users can run and save Model Lab work for {entitlement.RequiredLeagueName} only."
