@page "/"
@page "/rankings"
@rendermode @(new InteractiveServerRenderMode(prerender: true))
@using System.Globalization
@using Microsoft.AspNetCore.Components
@using BasketElo.Domain.Elo
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Basket ELO Rankings</PageTitle>

<div class="rankings-page">
    <nav class="rating-pool-tabs" aria-label="Rating pools">
        @foreach (var option in EloPoolCatalog.All.OrderBy(x => x.DisplayOrder))
        {
            <button type="button" class="@PoolTabClass(option.Key)" @onclick="() => SelectPoolAsync(option.Key)" disabled="@isBusy">
                @option.DisplayName
            </button>
        }
    </nav>

    <section class="rankings-hero">
        <div>
            <p class="eyebrow">Basket ELO</p>
            <h1>@PoolHeading()</h1>
            <p class="intro">@PoolIntroduction()</p>
        </div>

        @if (response?.Summary is not null)
        {
            <div class="leader-strip" aria-label="Top ranked team">
                <span>@LeaderLabel()</span>
                <strong>@(response.Summary.TopTeamName ?? "-")</strong>
                <small>@FormatRating(response.Summary.TopTeamElo)</small>
            </div>
        }
    </section>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger" role="alert">
            @errorMessage
        </div>
    }

    <section class="ranking-filters" aria-label="Ranking filters">
        @if (selectedPool == EloPoolKeys.Nba)
        {
            <div class="franchise-scope-field">
                <div>
                    <span class="filter-label">Franchises</span>
                    <div class="franchise-scope-control" role="group" aria-label="NBA franchise scope">
                        <button type="button" class="@TeamScopeClass(EloNbaTeamScopes.Current)" @onclick="() => SelectTeamScopeAsync(EloNbaTeamScopes.Current)" disabled="@isBusy">
                            Current
                        </button>
                        <button type="button" class="@TeamScopeClass(EloNbaTeamScopes.Historical)" @onclick="() => SelectTeamScopeAsync(EloNbaTeamScopes.Historical)" disabled="@isBusy">
                            Historical
                        </button>
                    </div>
                </div>
                <p>Current shows active NBA franchises. Historical also includes franchises that no longer compete.</p>
            </div>
        }

        <div class="filter-field wide">
            <label for="teamSearch">Team</label>
            <div class="clearable-field">
                <input id="teamSearch" class="form-control" @bind="teamSearch" @bind:event="oninput" placeholder="Search teams" />
                <button type="button" class="clear-filter" aria-label="Clear team search" title="Clear team search" @onclick="ClearTeamSearch" disabled="@(!HasTeamSearch)">
                    &times;
                </button>
            </div>
        </div>

        @if (selectedPool != EloPoolKeys.Nba)
        {
            <div class="filter-field">
                <label for="countryFilter">Country</label>
                <select id="countryFilter" class="form-select" @bind="selectedCountry">
                    <option value="">All countries</option>
                    @foreach (var option in response?.Filters.Countries ?? [])
                    {
                        <option value="@option">@option</option>
                    }
                </select>
            </div>
        }

        @if (selectedPool == EloPoolKeys.EuropeClubs)
        {
            <div class="filter-field">
                <label for="competitionFilter">Competition</label>
                <select id="competitionFilter" class="form-select" @bind="selectedCompetition">
                    <option value="">All competitions</option>
                    @foreach (var option in response?.Filters.Competitions ?? [])
                    {
                        <option value="@option">@option</option>
                    }
                </select>
            </div>
        }

        <div class="filter-field">
            <label for="fromSeasonFilter">From season</label>
            <select id="fromSeasonFilter" class="form-select" @bind="selectedFromSeason">
                <option value="">All history</option>
                @foreach (var option in response?.Filters.Seasons ?? [])
                {
                    <option value="@option">@option</option>
                }
            </select>
        </div>

        <div class="filter-field">
            <label for="toSeasonFilter">To season</label>
            <select id="toSeasonFilter" class="form-select" @bind="selectedToSeason">
                <option value="">Current</option>
                @foreach (var option in response?.Filters.Seasons ?? [])
                {
                    <option value="@option">@option</option>
                }
            </select>
        </div>

        <div class="filter-field compact">
            <label for="minGames">Min games</label>
            <input id="minGames" class="form-control" type="number" min="0" max="999" @bind="minimumGames" />
        </div>

        <div class="filter-actions">
            <button class="btn btn-primary" @onclick="ApplyFiltersAsync" disabled="@isBusy">Apply</button>
            <button class="btn btn-outline-secondary" @onclick="ResetFiltersAsync" disabled="@isBusy">Reset</button>
        </div>
    </section>

    <nav class="ranking-view-tabs" aria-label="Ranking views">
        <button type="button" class='@ViewTabClass("rankings")' @onclick='() => SelectViewAsync("rankings")' disabled="@isBusy">
            Rankings
        </button>
        <button type="button" class='@ViewTabClass("movers")' @onclick='() => SelectViewAsync("movers")' disabled="@isBusy">
            Biggest movers
        </button>
    </nav>

    @if (isBusy && response is null)
    {
        <section class="loading-panel">Loading rankings...</section>
    }
    else if (response is not null)
    {
        <section class="ranking-summary">
            <div>
                <span>Rated teams</span>
                <strong>@response.Summary.RatedTeams</strong>
            </div>
            <div>
                <span>Showing</span>
                <strong>@response.Summary.FilteredTeams</strong>
            </div>
            <div>
                <span>@LatestGameLabel()</span>
                <strong>@FormatDate(response.Summary.LatestGameUtc)</strong>
            </div>
            <div>
                <span>Ruleset</span>
                <strong>@response.RulesetVersion</strong>
            </div>
        </section>

        @if (IsArchiveMode)
        {
            <section class="archive-state">
                <strong>@ArchiveStateTitle()</strong>
                <span>@ArchiveStateDetail()</span>
            </section>
        }

        @if (selectedView == "movers")
        {
            <section class="movers-section">
                <div class="section-head">
                    <div>
                        <h2>@MoversTitle()</h2>
                        <p>@MoversContextLabel()</p>
                    </div>
                    <div class="pager">
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="PreviousPageAsync" disabled="@(isBusy || CurrentPage <= 1)">Previous</button>
                        <label class="page-jump" for="moversPageInput">
                            <span>Page</span>
                            <input id="moversPageInput" class="form-control form-control-sm" type="number" min="1" max="@CurrentTotalPages" @bind="requestedPage" @onkeydown="HandlePageInputKeyDown" />
                        </label>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="GoToRequestedPageAsync" disabled="@isBusy">Go</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="NextPageAsync" disabled="@(isBusy || CurrentPage >= CurrentTotalPages)">Next</button>
                    </div>
                </div>

                <div class="movers-toolbar" aria-label="Movement controls">
                    <label for="moverDirection">
                        <span>Movement</span>
                        <select id="moverDirection" class="form-select form-select-sm" value="@selectedMoverDirection" @onchange="ChangeMoverDirectionAsync">
                            <option value="risers">Risers</option>
                            <option value="fallers">Fallers</option>
                        </select>
                    </label>
                    <label for="windowDays">
                        <span>Window</span>
                        <select id="windowDays" class="form-select form-select-sm" value="@selectedWindowDays" @onchange="ChangeMoverWindowAsync">
                            <option value="7">7 days</option>
                            <option value="30">30 days</option>
                            <option value="90">90 days</option>
                        </select>
                    </label>
                </div>

                <div class="table-responsive ranking-table-wrap">
                    <table class="table table-hover align-middle ranking-table">
                        <thead>
                            <tr>
                                <th>Rank</th>
                                <th>Team</th>
                                @if (selectedPool != EloPoolKeys.Nba)
                                {
                                    <th>Country</th>
                                }
                                <th class="numeric">Change</th>
                                <th class="numeric">Start</th>
                                <th class="numeric">End</th>
                                <th class="numeric">Current</th>
                                <th class="numeric">Games</th>
                                <th>Latest</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (movers is null || movers.Movers.Count == 0)
                            {
                                <tr>
                                    <td colspan="9" class="empty-state">No rating movement is available for the selected scope.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var row in movers.Movers)
                                {
                                    <tr class="team-row" tabindex="0" @onclick="() => OpenTeam(row.TeamId)" @onkeydown="args => OpenTeamFromKeyboard(args, row.TeamId)">
                                        <td class="rank-cell">#@row.Rank</td>
                                        <td>
                                            <div class="team-identity-cell">
                                                <div>
                                                    <a class="team-link" href="@BuildTeamHref(row.TeamId)" @onclick:stopPropagation="true">@row.TeamName</a>
                                                    @if (!row.IsActive)
                                                    {
                                                        <span class="franchise-status">Defunct</span>
                                                    }
                                                </div>
                                            </div>
                                        </td>
                                        @if (selectedPool != EloPoolKeys.Nba)
                                        {
                                            <td>@row.Country</td>
                                        }
                                        <td class="numeric"><span class="@MovementClass(row.EloChange)">@FormatMovement(row.EloChange)</span></td>
                                        <td class="numeric">@row.StartElo.ToString("0")</td>
                                        <td class="numeric">@row.EndElo.ToString("0")</td>
                                        <td class="numeric rating">@row.CurrentElo.ToString("0")</td>
                                        <td class="numeric">@row.GamesInWindow</td>
                                        <td>@FormatDate(row.LastGameUtc)</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }
        @if (selectedView != "movers" && response.Rankings.Count > 0)
        {
            <section class="evolution-section">
                <div class="section-head">
                    <div>
                        <h2>ELO evolution</h2>
                        <p>@EvolutionContextLabel()</p>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ToggleChartSize">
                        @(isChartExpanded ? "Compact chart" : "Expand chart")
                    </button>
                </div>

                <div class="@EvolutionChartClass" role="img" aria-label="ELO evolution for teams in the current ranking table">
                    @if (EvolutionSeries.Count < 1 || EvolutionSeries.All(x => x.Points.Count < 2))
                    {
                        <div class="empty-state">Not enough rated games for an evolution chart yet.</div>
                    }
                    else
                    {
                        <EloEvolutionChart @key="activeRankingsCacheKey"
                                           Series="@evolutionChartSeries"
                                           EnableRangeNavigation="true"
                                           ShowLegend="false"
                                           SharedTooltip="false"
                                           HeightPixels="@ChartHeightPixels"
                                           DataRevision="@evolutionDataRevision"
                                           IsRefining="@isEvolutionRefining"
                                           ViewportRefinementRequested="@QueueEvolutionRefinementAsync"
                                           FullRangeRequested="@RestoreFullEvolutionAsync" />

                        <div class="evolution-legend legacy-links" aria-label="ELO evolution chart team links">
                            @foreach (var item in EvolutionSeries.Select((series, index) => new { series, index }))
                            {
                                <a href="@BuildTeamHref(item.series.TeamId)">
                                    <span style="background: @ChartColor(item.index)"></span>
                                    @item.series.TeamName
                                </a>
                            }
                        </div>
                    }
                </div>
            </section>
        }

        @if (selectedView != "movers")
        {
            <section class="rankings-table-section">
                <div class="section-head">
                    <div>
                        <h2>Ranking table</h2>
                        <p>@TableContextLabel()</p>
                    </div>
                    <div class="pager">
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="PreviousPageAsync" disabled="@(isBusy || CurrentPage <= 1)">Previous</button>
                        <label class="page-jump" for="rankingsPageInput">
                            <span>Page</span>
                            <input id="rankingsPageInput" class="form-control form-control-sm" type="number" min="1" max="@CurrentTotalPages" @bind="requestedPage" @onkeydown="HandlePageInputKeyDown" />
                        </label>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="GoToRequestedPageAsync" disabled="@isBusy">Go</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="NextPageAsync" disabled="@(isBusy || CurrentPage >= CurrentTotalPages)">Next</button>
                    </div>
                </div>

                <div class="table-responsive ranking-table-wrap">
                    <table class="table table-hover align-middle ranking-table">
                        <thead>
                            <tr>
                                <th>Rank</th>
                                @if (response.Summary.IsFiltered)
                                {
                                    <th>Pool</th>
                                }
                                <th>Team</th>
                                @if (selectedPool != EloPoolKeys.Nba)
                                {
                                    <th>Country</th>
                                }
                                <th class="numeric">ELO</th>
                                <th class="numeric">Games</th>
                                <th class="numeric">Last</th>
                                <th>Last game</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (response.Rankings.Count == 0)
                            {
                                <tr>
                                    <td colspan="8" class="empty-state">@(selectedPool == EloPoolKeys.NationalTeams ? "National team ratings are not available yet." : "No teams match the current filters.")</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var row in response.Rankings)
                                {
                                    <tr class="team-row" tabindex="0" @onclick="() => OpenTeam(row.TeamId)" @onkeydown="args => OpenTeamFromKeyboard(args, row.TeamId)">
                                        <td class="rank-cell">#@row.Rank</td>
                                        @if (response.Summary.IsFiltered)
                                        {
                                            <td class="muted-rank">#@row.GlobalRank</td>
                                        }
                                        <td>
                                            <div class="team-identity-cell">
                                                <div>
                                                    <a class="team-link" href="@BuildTeamHref(row.TeamId)" @onclick:stopPropagation="true">@row.TeamName</a>
                                                    @if (!row.IsActive)
                                                    {
                                                        <span class="franchise-status">Defunct</span>
                                                    }
                                                </div>
                                            </div>
                                        </td>
                                        @if (selectedPool != EloPoolKeys.Nba)
                                        {
                                            <td>@row.Country</td>
                                        }
                                        <td class="numeric rating">@row.Elo.ToString("0")</td>
                                        <td class="numeric">@row.GamesPlayed</td>
                                        <td class="numeric">
                                            <span class="@MovementClass(row.RecentMovement)">@FormatMovement(row.RecentMovement)</span>
                                        </td>
                                        <td>@FormatDate(row.LastGameUtc)</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "pool")]
    public string? Pool { get; set; }

    [SupplyParameterFromQuery(Name = "country")]
    public string? Country { get; set; }

    [SupplyParameterFromQuery(Name = "competition")]
    public string? Competition { get; set; }

    [SupplyParameterFromQuery(Name = "season")]
    public string? Season { get; set; }

    [SupplyParameterFromQuery(Name = "fromSeason")]
    public string? FromSeason { get; set; }

    [SupplyParameterFromQuery(Name = "toSeason")]
    public string? ToSeason { get; set; }

    [SupplyParameterFromQuery(Name = "from")]
    public DateTime? From { get; set; }

    [SupplyParameterFromQuery(Name = "to")]
    public DateTime? To { get; set; }

    [SupplyParameterFromQuery(Name = "minGames")]
    public int? MinGames { get; set; }

    [SupplyParameterFromQuery(Name = "team")]
    public string? Team { get; set; }

    [SupplyParameterFromQuery(Name = "teams")]
    public string? Teams { get; set; }

    [SupplyParameterFromQuery(Name = "view")]
    public string? View { get; set; }

    [SupplyParameterFromQuery(Name = "movement")]
    public string? Movement { get; set; }

    [SupplyParameterFromQuery(Name = "windowDays")]
    public int? WindowDays { get; set; }

    [SupplyParameterFromQuery(Name = "page")]
    public int? Page { get; set; }

    private EloRankingsResponse? response;
    private EloMoversResponse? movers;
    private EloRankingsEvolutionResponse? evolution;
    private EloRankingsEvolutionResponse? fullEvolution;
    private EloRankingsResponse? evolutionRankings;
    private IReadOnlyList<EloChartSeries> evolutionChartSeries = [];
    private bool isBusy;
    private bool isChartExpanded;
    private string? errorMessage;
    private string? selectedCountry;
    private string? selectedCompetition;
    private string selectedPool = EloPoolKeys.Default;
    private string selectedTeamScope = EloNbaTeamScopes.Current;
    private string? selectedFromSeason;
    private string? selectedToSeason;
    private string? teamSearch;
    private int minimumGames;
    private int page = 1;
    private int requestedPage = 1;
    private string selectedView = "rankings";
    private string selectedMoverDirection = "risers";
    private int selectedWindowDays = 30;
    private string? lastLoadedUri;
    private string? lastRankingsApiUri;
    private string? lastMoversApiUri;
    private string? lastEvolutionRankingsApiUri;
    private string? lastEvolutionApiUri;
    private RankingsClientCacheKey? activeRankingsCacheKey;
    private long evolutionDataRevision;
    private bool isEvolutionRefining;
    private readonly Dictionary<Guid, int> evolutionVisibleRatedPointCounts = new();
    private CancellationTokenSource? evolutionRefinementCancellation;
    private readonly Dictionary<RankingsClientCacheKey, RankingsClientCacheEntry> rankingsClientCache = new();
    private readonly Dictionary<string, EloRankingsEvolutionResponse> evolutionRangeCache = new(StringComparer.Ordinal);
    private readonly Queue<string> evolutionRangeCacheOrder = new();

    private const int EvolutionRefinementDebounceMilliseconds = 600;
    private const int EvolutionRangeCacheLimit = 8;

    private sealed record RankingsClientCacheKey(
        string Pool,
        string View,
        string RankingsUri,
        string MoverDirection,
        int MoverWindowDays);

    private sealed class RankingsClientCacheEntry
    {
        public EloRankingsResponse? Rankings { get; set; }
        public EloMoversResponse? Movers { get; set; }
        public EloRankingsEvolutionResponse? Evolution { get; set; }
        public EloRankingsEvolutionResponse? FullEvolution { get; set; }
        public EloRankingsResponse? EvolutionRankings { get; set; }
        public IReadOnlyList<EloChartSeries> EvolutionChartSeries { get; set; } = [];
        public Dictionary<Guid, int> EvolutionVisibleRatedPointCounts { get; set; } = new();
        public string? RankingsApiUri { get; set; }
        public string? MoversApiUri { get; set; }
        public string? EvolutionRankingsApiUri { get; set; }
        public string? EvolutionApiUri { get; set; }
        public long EvolutionDataRevision { get; set; }
    }

    protected override async Task OnParametersSetAsync()
    {
        var currentUri = Navigation.Uri;
        if (currentUri == lastLoadedUri)
        {
            return;
        }

        CaptureActiveRankingsCacheEntry();

        selectedPool = EloPoolKeys.IsSupported(Pool?.Trim().ToLowerInvariant() ?? string.Empty)
            ? Pool!.Trim().ToLowerInvariant()
            : EloPoolKeys.Default;
        selectedTeamScope = selectedPool == EloPoolKeys.Nba
            ? EloNbaTeamScopes.Normalize(Teams)
            : EloNbaTeamScopes.Current;
        selectedCountry = Country;
        selectedCompetition = Competition;
        selectedFromSeason = FromSeason;
        selectedToSeason = ToSeason;
        if (!string.IsNullOrWhiteSpace(Season) && string.IsNullOrWhiteSpace(selectedFromSeason) && string.IsNullOrWhiteSpace(selectedToSeason))
        {
            selectedFromSeason = Season;
            selectedToSeason = Season;
        }
        else
        {
            ApplyLegacyDateRange();
        }
        minimumGames = Math.Max(0, MinGames ?? 0);
        teamSearch = Team;
        selectedView = string.Equals(View, "movers", StringComparison.OrdinalIgnoreCase) ? "movers" : "rankings";
        selectedMoverDirection = string.Equals(Movement, "fallers", StringComparison.OrdinalIgnoreCase) ? "fallers" : "risers";
        selectedWindowDays = WindowDays is 7 or 30 or 90 ? WindowDays.Value : 30;
        page = Math.Max(1, Page ?? 1);
        requestedPage = page;
        lastLoadedUri = currentUri;
        CancelEvolutionRefinement();
        evolutionRangeCache.Clear();
        evolutionRangeCacheOrder.Clear();

        activeRankingsCacheKey = null;
        response = null;
        movers = null;
        evolution = null;
        evolutionRankings = null;
        evolutionChartSeries = [];
        fullEvolution = null;

        await RefreshAsync();
    }

    private Task ApplyFiltersAsync()
    {
        NavigateToRankings(1);
        return Task.CompletedTask;
    }

    private Task ResetFiltersAsync()
    {
        selectedTeamScope = EloNbaTeamScopes.Current;
        selectedCountry = null;
        selectedCompetition = null;
        selectedFromSeason = null;
        selectedToSeason = null;
        minimumGames = 0;
        teamSearch = null;
        NavigateToRankings(1);
        return Task.CompletedTask;
    }

    private Task SelectViewAsync(string view)
    {
        selectedView = string.Equals(view, "movers", StringComparison.OrdinalIgnoreCase) ? "movers" : "rankings";
        NavigateToRankings(1);
        return Task.CompletedTask;
    }

    private Task SelectTeamScopeAsync(string teamScope)
    {
        selectedTeamScope = EloNbaTeamScopes.Normalize(teamScope);
        NavigateToRankings(1);
        return Task.CompletedTask;
    }

    private Task SelectPoolAsync(string poolKey)
    {
        selectedPool = EloPoolKeys.Normalize(poolKey);
        selectedTeamScope = EloNbaTeamScopes.Current;
        selectedCountry = null;
        selectedCompetition = null;
        selectedFromSeason = null;
        selectedToSeason = null;
        minimumGames = 0;
        teamSearch = null;
        page = 1;
        lastRankingsApiUri = null;
        lastMoversApiUri = null;
        lastEvolutionRankingsApiUri = null;
        lastEvolutionApiUri = null;
        NavigateToRankings(1);
        return Task.CompletedTask;
    }

    private Task ClearTeamSearch()
    {
        teamSearch = null;
        NavigateToRankings(1);
        return Task.CompletedTask;
    }

    private Task ChangeMoverDirectionAsync(ChangeEventArgs args)
    {
        selectedMoverDirection = string.Equals(args.Value?.ToString(), "fallers", StringComparison.OrdinalIgnoreCase)
            ? "fallers"
            : "risers";
        NavigateToRankings(1);
        return Task.CompletedTask;
    }

    private Task ChangeMoverWindowAsync(ChangeEventArgs args)
    {
        selectedWindowDays = int.TryParse(args.Value?.ToString(), out var value) && value is 7 or 30 or 90
            ? value
            : 30;
        NavigateToRankings(1);
        return Task.CompletedTask;
    }

    private void ToggleChartSize()
    {
        isChartExpanded = !isChartExpanded;
    }

    private Task PreviousPageAsync()
    {
        NavigateToRankings(Math.Max(1, CurrentPage - 1));
        return Task.CompletedTask;
    }

    private Task NextPageAsync()
    {
        NavigateToRankings(Math.Min(CurrentTotalPages, CurrentPage + 1));
        return Task.CompletedTask;
    }

    private Task GoToRequestedPageAsync()
    {
        NavigateToRankings(ClampRequestedPage(requestedPage, CurrentTotalPages));
        return Task.CompletedTask;
    }

    private async Task HandlePageInputKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            await GoToRequestedPageAsync();
        }
    }

    private async Task RefreshAsync()
    {
        isBusy = true;
        errorMessage = null;

        try
        {
            var rankingsUri = BuildApiUri();
            var cacheKey = BuildRankingsClientCacheKey(rankingsUri);
            if (rankingsClientCache.TryGetValue(cacheKey, out var cachedEntry))
            {
                RestoreRankingsCacheEntry(cacheKey, cachedEntry);
                return;
            }

            if (response is null ||
                !string.Equals(rankingsUri, lastRankingsApiUri, StringComparison.Ordinal) ||
                activeRankingsCacheKey != cacheKey)
            {
                response = await Http.GetFromJsonAsync<EloRankingsResponse>(rankingsUri);
                lastRankingsApiUri = rankingsUri;
            }

            if (response is not null)
            {
                page = response.Page;
                requestedPage = response.Page;
            }

            if (selectedView == "movers")
            {
                var moversUri = BuildMoversApiUri();
                if (movers is null || !string.Equals(moversUri, lastMoversApiUri, StringComparison.Ordinal))
                {
                    movers = await Http.GetFromJsonAsync<EloMoversResponse>(moversUri);
                    lastMoversApiUri = moversUri;
                }

                if (movers is not null)
                {
                    page = movers.Page;
                    requestedPage = movers.Page;
                }
            }
            else
            {
                evolutionRankings = await FetchEvolutionRankingsAsync();
                evolution = await FetchEvolutionAsync();
                fullEvolution = evolution;
                RebuildEvolutionChartSeries();
            }

            StoreRankingsCacheEntry(cacheKey);
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not load rankings: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }

    private RankingsClientCacheKey BuildRankingsClientCacheKey(string rankingsUri)
        => new(
            selectedPool,
            selectedView,
            rankingsUri,
            selectedView == "movers" ? selectedMoverDirection : string.Empty,
            selectedView == "movers" ? selectedWindowDays : 0);

    private void CaptureActiveRankingsCacheEntry()
    {
        if (activeRankingsCacheKey is null ||
            !rankingsClientCache.TryGetValue(activeRankingsCacheKey, out var entry))
        {
            return;
        }

        entry.Rankings = response;
        entry.Movers = movers;
        entry.Evolution = evolution;
        entry.FullEvolution = fullEvolution;
        entry.EvolutionRankings = evolutionRankings;
        entry.EvolutionChartSeries = evolutionChartSeries.ToList();
        entry.EvolutionVisibleRatedPointCounts = new(evolutionVisibleRatedPointCounts);
        entry.RankingsApiUri = lastRankingsApiUri;
        entry.MoversApiUri = lastMoversApiUri;
        entry.EvolutionRankingsApiUri = lastEvolutionRankingsApiUri;
        entry.EvolutionApiUri = lastEvolutionApiUri;
        entry.EvolutionDataRevision = evolutionDataRevision;
    }

    private void StoreRankingsCacheEntry(RankingsClientCacheKey cacheKey)
    {
        var entry = rankingsClientCache.TryGetValue(cacheKey, out var existing)
            ? existing
            : new RankingsClientCacheEntry();

        entry.Rankings = response;
        entry.Movers = movers;
        entry.Evolution = evolution;
        entry.FullEvolution = fullEvolution;
        entry.EvolutionRankings = evolutionRankings;
        entry.EvolutionChartSeries = evolutionChartSeries.ToList();
        entry.EvolutionVisibleRatedPointCounts = new(evolutionVisibleRatedPointCounts);
        entry.RankingsApiUri = lastRankingsApiUri;
        entry.MoversApiUri = lastMoversApiUri;
        entry.EvolutionRankingsApiUri = lastEvolutionRankingsApiUri;
        entry.EvolutionApiUri = lastEvolutionApiUri;
        entry.EvolutionDataRevision = evolutionDataRevision;

        rankingsClientCache[cacheKey] = entry;
        activeRankingsCacheKey = cacheKey;
    }

    private void RestoreRankingsCacheEntry(
        RankingsClientCacheKey cacheKey,
        RankingsClientCacheEntry entry)
    {
        response = entry.Rankings;
        movers = entry.Movers;
        evolution = entry.Evolution;
        fullEvolution = entry.FullEvolution;
        evolutionRankings = entry.EvolutionRankings;
        evolutionChartSeries = entry.EvolutionChartSeries.ToList();
        evolutionVisibleRatedPointCounts.Clear();
        foreach (var item in entry.EvolutionVisibleRatedPointCounts)
        {
            evolutionVisibleRatedPointCounts[item.Key] = item.Value;
        }

        lastRankingsApiUri = entry.RankingsApiUri;
        lastMoversApiUri = entry.MoversApiUri;
        lastEvolutionRankingsApiUri = entry.EvolutionRankingsApiUri;
        lastEvolutionApiUri = entry.EvolutionApiUri;
        evolutionDataRevision = entry.EvolutionDataRevision;
        activeRankingsCacheKey = cacheKey;

        if (response is not null)
        {
            page = response.Page;
            requestedPage = response.Page;
        }
        else if (movers is not null)
        {
            page = movers.Page;
            requestedPage = movers.Page;
        }
    }

    private void NavigateToRankings(int targetPage)
    {
        NormalizeSelectedSeasonRange();
        targetPage = ClampRequestedPage(targetPage, CurrentTotalPages);
        page = targetPage;
        lastLoadedUri = null;

        var query = new Dictionary<string, object?>
        {
            ["pool"] = selectedPool == EloPoolKeys.Default ? null : selectedPool,
            ["teams"] = selectedPool == EloPoolKeys.Nba && selectedTeamScope == EloNbaTeamScopes.Historical
                ? selectedTeamScope
                : null,
            ["view"] = selectedView == "movers" ? selectedView : null,
            ["movement"] = selectedView == "movers" ? selectedMoverDirection : null,
            ["windowDays"] = selectedView == "movers" && selectedWindowDays != 30 ? selectedWindowDays : null,
            ["country"] = selectedCountry,
            ["competition"] = selectedCompetition,
            ["fromSeason"] = selectedFromSeason,
            ["toSeason"] = selectedToSeason,
            ["minGames"] = minimumGames > 0 ? minimumGames : null,
            ["team"] = teamSearch,
            ["page"] = targetPage > 1 ? targetPage : null
        };

        Navigation.NavigateTo(Navigation.GetUriWithQueryParameters("/rankings", query));
    }

    private static int ClampRequestedPage(int value, int totalPages)
        => Math.Clamp(value, 1, Math.Max(1, totalPages));

    private void ApplyLegacyDateRange()
    {
        if (string.IsNullOrWhiteSpace(selectedFromSeason) && From.HasValue)
        {
            selectedFromSeason = GetSeasonLabelForDate(From.Value);
        }

        if (string.IsNullOrWhiteSpace(selectedToSeason) && To.HasValue)
        {
            selectedToSeason = GetSeasonLabelForDate(To.Value);
        }
    }

    private void NormalizeSelectedSeasonRange()
    {
        if (TryParseSeasonStartYear(selectedFromSeason, out var fromYear) &&
            TryParseSeasonStartYear(selectedToSeason, out var toYear) &&
            fromYear > toYear)
        {
            (selectedFromSeason, selectedToSeason) = (selectedToSeason, selectedFromSeason);
        }
    }

    private (DateTime? FromUtc, DateTime? ToUtc, DateTime? AsOfUtc) GetSelectedSeasonDateRange()
    {
        NormalizeSelectedSeasonRange();

        var fromUtc = TryGetSeasonStart(selectedFromSeason, out var seasonStart)
            ? seasonStart
            : (DateTime?)null;
        var toDate = TryGetSeasonEndDate(selectedToSeason, out var seasonEndDate)
            ? seasonEndDate
            : (DateTime?)null;
        var toUtc = NormalizeInclusiveDateEnd(toDate);

        return (fromUtc, toUtc, toDate);
    }

    private static bool TryGetSeasonStart(string? season, out DateTime startUtc)
    {
        startUtc = default;
        if (!TryParseSeasonStartYear(season, out var startYear))
        {
            return false;
        }

        startUtc = new DateTime(startYear, 8, 1, 0, 0, 0, DateTimeKind.Utc);
        return true;
    }

    private static bool TryGetSeasonEndDate(string? season, out DateTime endDateUtc)
    {
        endDateUtc = default;
        if (!TryParseSeasonStartYear(season, out var startYear))
        {
            return false;
        }

        endDateUtc = new DateTime(startYear + 1, 7, 31, 0, 0, 0, DateTimeKind.Utc);
        return true;
    }

    private static bool TryParseSeasonStartYear(string? season, out int startYear)
    {
        startYear = default;
        if (string.IsNullOrWhiteSpace(season))
        {
            return false;
        }

        var parts = season.Split('-', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries);
        return parts.Length == 2 &&
               int.TryParse(parts[0], NumberStyles.None, CultureInfo.InvariantCulture, out startYear) &&
               int.TryParse(parts[1], NumberStyles.None, CultureInfo.InvariantCulture, out var endYear) &&
               endYear == startYear + 1;
    }

    private static string GetSeasonLabelForDate(DateTime value)
    {
        var date = value.Date;
        return date.Month >= 8
            ? $"{date.Year}-{date.Year + 1}"
            : $"{date.Year - 1}-{date.Year}";
    }

