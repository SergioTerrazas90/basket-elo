@page "/teams/{TeamId:guid}"
@attribute [Authorize]
@rendermode InteractiveServer
@using System.Globalization
@using System.Text.Json
@using BasketElo.Domain.Elo
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>@(team?.TeamName ?? "Team") - Basket ELO</PageTitle>

<div class="team-page">
    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger" role="alert">
            @errorMessage
        </div>
    }

    @if (isBusy && team is null)
    {
        <section class="loading-panel">Loading team profile...</section>
    }
    else if (team is not null)
    {
        <section class="team-hero">
            <div>
                <a class="back-link" href="@BackHref">Back to rankings</a>
                <p class="eyebrow">@team.Country</p>
                <h1>@team.TeamName</h1>
                <p class="intro">Current adjusted ELO profile, recent rated games, and rating path.</p>
            </div>
            <div class="team-rank-card">
                <span>Global rank</span>
                <strong>#@team.GlobalRank</strong>
                <small>@team.RulesetVersion</small>
            </div>
        </section>

        <section class="team-summary">
            <div>
                <span>Current ELO</span>
                <strong>@team.Elo.ToString("0")</strong>
            </div>
            <div>
                <span>Games rated</span>
                <strong>@team.GamesPlayed</strong>
            </div>
            <div>
                <span>Recent movement</span>
                <strong class="@MovementClass(team.RecentMovement)">@FormatMovement(team.RecentMovement)</strong>
            </div>
            <div>
                <span>Last game</span>
                <strong>@FormatDate(team.LastGameUtc)</strong>
            </div>
        </section>

        @if (team.RecentForms.Count > 0)
        {
            <section class="form-section">
                <div class="section-head">
                    <div>
                        <h2>Recent form</h2>
                        <p>Latest rated games summarized by record, rating movement, and opponent strength.</p>
                    </div>
                </div>

                <div class="form-grid">
                    @foreach (var form in team.RecentForms)
                    {
                        <article class="form-card">
                            <div class="form-card-head">
                                <span>Last @form.WindowGames</span>
                                <strong>@FormatRecord(form)</strong>
                            </div>

                            <dl class="form-stats">
                                <div>
                                    <dt>Rated games</dt>
                                    <dd>@form.GamesAvailable</dd>
                                </div>
                                <div>
                                    <dt>ELO change</dt>
                                    <dd class="@MovementClass(form.TotalEloChange)">@FormatMovement(form.TotalEloChange)</dd>
                                </div>
                                <div>
                                    <dt>Avg opponent</dt>
                                    <dd>@FormatRating(form.AverageOpponentPreElo)</dd>
                                </div>
                            </dl>

                            <div class="form-highlights">
                                <div>
                                    <span>Best win</span>
                                    <strong>@FormatFormGame(form.BestWin)</strong>
                                </div>
                                <div>
                                    <span>Worst loss</span>
                                    <strong>@FormatFormGame(form.WorstLoss)</strong>
                                </div>
                            </div>
                        </article>
                    }
                </div>
            </section>
        }

        <section class="team-context">
            <div>
                <h2>Competitions</h2>
                <div class="competition-list">
                    @if (team.Competitions.Count == 0)
                    {
                        <span class="empty-chip">No competitions yet</span>
                    }
                    else
                    {
                        @foreach (var competition in team.Competitions)
                        {
                            <span>@competition</span>
                        }
                    }
                </div>
            </div>
        </section>

        <section class="history-section">
            <div class="section-head">
                <div>
                    <h2>Rating history</h2>
                    <p>@HistoryContextLabel(team)</p>
                </div>
            </div>
            <div class="chart-shell">
                @if (team.History.Count < 2)
                {
                    <div class="empty-state">Not enough rated games for a chart yet.</div>
                }
                else
                {
                    <EloEvolutionChart Series="@BuildTeamChartSeries(team)" ShowLegend="false" SharedTooltip="false" EnableRangeNavigation="true" />
                }
            </div>
        </section>

        <section class="recent-games-section">
            <div class="section-head">
                <div>
                    <h2>Rated games</h2>
                    <p>@GamesContextLabel(team)</p>
                </div>
                <div class="pager">
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="PreviousGamesPageAsync" disabled="@isBusy || team.RecentGamesPage <= 1">Previous</button>
                    <label class="page-jump" for="teamGamesPageInput">
                        <span>Page</span>
                        <input id="teamGamesPageInput" class="form-control form-control-sm" type="number" min="1" max="@team.RecentGamesTotalPages" @bind="requestedGamesPage" @onkeydown="HandleGamesPageInputKeyDown" />
                    </label>
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="GoToRequestedGamesPageAsync" disabled="@isBusy">Go</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="NextGamesPageAsync" disabled="@isBusy || team.RecentGamesPage >= team.RecentGamesTotalPages">Next</button>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle team-games-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Competition</th>
                            <th>Opponent</th>
                            <th>Score</th>
                            <th class="numeric">ELO change</th>
                            <th class="numeric">After</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (team.RecentGames.Count == 0)
                        {
                            <tr>
                                <td colspan="7" class="empty-state">No rated games are available for this team.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var game in team.RecentGames)
                            {
                                <tr>
                                    <td>@FormatDate(game.GameDateTimeUtc)</td>
                                    <td>
                                        <div class="competition-cell">
                                            <span>@game.Competition</span>
                                            <small>@game.Season</small>
                                        </div>
                                    </td>
                                    <td>@(game.WasHome ? "vs" : "at") @game.Opponent</td>
                                    <td>@FormatScore(game)</td>
                                    <td class="numeric"><span class="@MovementClass(game.EloDelta)">@FormatMovement(game.EloDelta)</span></td>
                                    <td class="numeric rating">@game.PostElo.ToString("0")</td>
                                    <td>
                                        <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => LoadExplanationAsync(game.GameId)" disabled="@IsExplanationLoading(game.GameId)">
                                            @(IsExplanationLoading(game.GameId) ? "Loading" : "Explain")
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

        </section>

        <GameEloExplanationPanel Explanation="selectedExplanation"
                                 IsLoading="isExplanationLoading"
                                 ErrorMessage="@explanationError"
                                 OnClose="CloseExplanation" />
    }
</div>

@code {
    [Parameter]
    public Guid TeamId { get; set; }

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "gamesPage")]
    public int? GamesPage { get; set; }

    private EloTeamDetailResponse? team;
    private bool isBusy;
    private string? errorMessage;
    private int gamesPage = 1;
    private int requestedGamesPage = 1;
    private Guid? selectedExplanationGameId;
    private EloGameExplanationResponse? selectedExplanation;
    private bool isExplanationLoading;
    private string? explanationError;

    private string BackHref => string.IsNullOrWhiteSpace(ReturnUrl) ? "/rankings" : "/" + ReturnUrl.TrimStart('/');

    protected override async Task OnParametersSetAsync()
    {
        isBusy = true;
        errorMessage = null;
        gamesPage = Math.Max(1, GamesPage ?? 1);
        requestedGamesPage = gamesPage;

        try
        {
            team = await Http.GetFromJsonAsync<EloTeamDetailResponse>($"api/elo/teams/{TeamId}?gamesPage={gamesPage}&gamesPageSize=25");
            if (team is not null)
            {
                gamesPage = team.RecentGamesPage;
                requestedGamesPage = team.RecentGamesPage;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not load team profile: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }

    private Task PreviousGamesPageAsync()
    {
        NavigateToGamesPage(Math.Max(1, (team?.RecentGamesPage ?? gamesPage) - 1));
        return Task.CompletedTask;
    }

    private Task NextGamesPageAsync()
    {
        if (team is not null)
        {
            NavigateToGamesPage(Math.Min(team.RecentGamesTotalPages, team.RecentGamesPage + 1));
        }

        return Task.CompletedTask;
    }

    private Task GoToRequestedGamesPageAsync()
    {
        NavigateToGamesPage(ClampRequestedPage(requestedGamesPage, team?.RecentGamesTotalPages ?? 1));
        return Task.CompletedTask;
    }

    private async Task HandleGamesPageInputKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            await GoToRequestedGamesPageAsync();
        }
    }

    private void NavigateToGamesPage(int targetPage)
    {
        targetPage = ClampRequestedPage(targetPage, team?.RecentGamesTotalPages ?? targetPage);
        CloseExplanation();

        var query = new Dictionary<string, object?>
        {
            ["returnUrl"] = ReturnUrl,
            ["gamesPage"] = targetPage > 1 ? targetPage : null
        };

        Navigation.NavigateTo(Navigation.GetUriWithQueryParameters($"/teams/{TeamId}", query));
    }

    private async Task LoadExplanationAsync(Guid gameId)
    {
        selectedExplanationGameId = gameId;
        selectedExplanation = null;
        explanationError = null;
        isExplanationLoading = true;

        try
        {
            using var responseMessage = await Http.GetAsync($"api/elo/games/{gameId}/explanation?rulesetVersion={Uri.EscapeDataString(team?.RulesetVersion ?? string.Empty)}");
            if (!responseMessage.IsSuccessStatusCode)
            {
                throw new InvalidOperationException(await ReadErrorMessageAsync(responseMessage));
            }

            selectedExplanation = await responseMessage.Content.ReadFromJsonAsync<EloGameExplanationResponse>();
            if (selectedExplanation is null)
            {
                throw new InvalidOperationException("The API returned an empty explanation.");
            }
        }
        catch (Exception ex)
        {
            explanationError = $"Could not load ELO explanation: {ex.Message}";
        }
        finally
        {
            isExplanationLoading = false;
        }
    }

    private bool IsExplanationLoading(Guid gameId)
        => isExplanationLoading && selectedExplanationGameId == gameId;

    private void CloseExplanation()
    {
        selectedExplanationGameId = null;
        selectedExplanation = null;
        explanationError = null;
        isExplanationLoading = false;
    }

    private static async Task<string> ReadErrorMessageAsync(HttpResponseMessage responseMessage)
    {
        var body = await responseMessage.Content.ReadAsStringAsync();
        if (string.IsNullOrWhiteSpace(body))
        {
            return responseMessage.ReasonPhrase ?? $"HTTP {(int)responseMessage.StatusCode}";
        }

        try
        {
            using var json = JsonDocument.Parse(body);
            if (json.RootElement.TryGetProperty("detail", out var detail) && detail.ValueKind == JsonValueKind.String)
            {
                return detail.GetString() ?? body;
            }

            if (json.RootElement.TryGetProperty("title", out var title) && title.ValueKind == JsonValueKind.String)
            {
                return title.GetString() ?? body;
            }

            if (json.RootElement.ValueKind == JsonValueKind.String)
            {
                return json.RootElement.GetString() ?? body;
            }
        }
        catch (JsonException)
        {
        }

        return body;
    }

    private static int ClampRequestedPage(int value, int totalPages)
        => Math.Clamp(value, 1, Math.Max(1, totalPages));

    private static IReadOnlyList<EloChartSeries> BuildTeamChartSeries(EloTeamDetailResponse team)
        =>
        [
            new EloChartSeries(
                team.TeamId,
                team.TeamName,
                "#245c7a",
                team.History
                    .OrderBy(point => point.GameDateTimeUtc)
                    .Select(point => new EloChartPoint(
                        point.GameDateTimeUtc,
                        point.Elo,
                        team.TeamName,
                        "#245c7a",
                        point.EloDelta,
                        point.Rank))
                    .ToList())
        ];

    private static string HistoryContextLabel(EloTeamDetailResponse team)
    {
        if (team.History.Count == 0)
        {
            return "No rated history yet.";
        }

        var first = team.History.Min(point => point.GameDateTimeUtc);
        var last = team.History.Max(point => point.GameDateTimeUtc);

        return $"{team.History.Count} rated points from {FormatDate(first)} to {FormatDate(last)}.";
    }

    private static string GamesContextLabel(EloTeamDetailResponse team)
    {
        if (team.RecentGamesTotalCount == 0)
        {
            return "No rated games are available for this team.";
        }

        var rangeStart = ((team.RecentGamesPage - 1) * team.RecentGamesPageSize) + 1;
        var rangeEnd = Math.Min(team.RecentGamesTotalCount, team.RecentGamesPage * team.RecentGamesPageSize);

        return $"Showing {rangeStart}-{rangeEnd} of {team.RecentGamesTotalCount} rated games. Page {team.RecentGamesPage} of {team.RecentGamesTotalPages}.";
    }

    private static string FormatScore(EloTeamGameDto game)
        => game.TeamScore.HasValue && game.OpponentScore.HasValue
            ? $"{game.TeamScore}-{game.OpponentScore}"
            : "-";

    private static string FormatDate(DateTime? value)
        => value.HasValue ? value.Value.ToLocalTime().ToString("MMM d, yyyy") : "-";

    private static string FormatRating(decimal value)
        => value == 0 ? "-" : value.ToString("0");

    private static string FormatMovement(decimal value)
        => value switch
        {
            > 0 => $"+{value:0}",
            < 0 => value.ToString("0"),
            _ => "0"
        };

    private static string FormatRecord(EloTeamFormSummary form)
        => form.GamesAvailable == 0 ? "No games" : $"{form.Wins}-{form.Losses}";

    private static string FormatFormGame(EloTeamFormGame? game)
    {
        if (game is null)
        {
            return "-";
        }

        var location = game.WasHome ? "vs" : "at";
        var score = game.TeamScore.HasValue && game.OpponentScore.HasValue
            ? $" {game.TeamScore}-{game.OpponentScore}"
            : string.Empty;

        return $"{location} {game.Opponent}{score} ({FormatMovement(game.EloDelta)})";
    }

    private static string MovementClass(decimal value)
        => value switch
        {
            > 0 => "movement-up",
            < 0 => "movement-down",
            _ => "movement-flat"
        };
}
