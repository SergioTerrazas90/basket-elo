@page "/games"
@rendermode InteractiveServer
@using System.Text.Json
@using BasketElo.Domain.Elo
@using BasketElo.Domain.Games
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Games</PageTitle>

<div class="games-page">
    <section class="page-header">
        <div>
            <p class="eyebrow">Data Browser</p>
            <h1>Games explorer</h1>
            <p class="intro">Browse imported games, narrow down the dataset quickly, and inspect exactly what has landed in the database.</p>
        </div>
        <div class="header-actions">
            <button class="btn btn-outline-secondary" @onclick="ResetFiltersAsync" disabled="@isBusy">Reset filters</button>
            <button class="btn btn-outline-primary" @onclick="RefreshAsync" disabled="@isBusy">Refresh</button>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger" role="alert">
            @errorMessage
        </div>
    }

    <section class="filters-panel">
        <div class="filter-field wide">
            <label for="searchInput">Search</label>
            <input id="searchInput" class="form-control" @bind="search" @bind:event="oninput" placeholder="League, team, season, status..." />
        </div>

        <div class="filter-field">
            <label for="teamInput">Team</label>
            <input id="teamInput" class="form-control" @bind="team" @bind:event="oninput" placeholder="Home or away team" />
        </div>

        <div class="filter-field">
            <label for="countryFilter">Country</label>
            <select id="countryFilter" class="form-select" @bind="selectedCountry">
                <option value="">All</option>
                @foreach (var option in response?.Filters.Countries ?? [])
                {
                    <option value="@option">@option</option>
                }
            </select>
        </div>

        <div class="filter-field">
            <label for="leagueFilter">League</label>
            <select id="leagueFilter" class="form-select" @bind="selectedLeague">
                <option value="">All</option>
                @foreach (var option in response?.Filters.Leagues ?? [])
                {
                    <option value="@option">@option</option>
                }
            </select>
        </div>

        <div class="filter-field">
            <label for="seasonFilter">Season</label>
            <select id="seasonFilter" class="form-select" @bind="selectedSeason">
                <option value="">All</option>
                @foreach (var option in response?.Filters.Seasons ?? [])
                {
                    <option value="@option">@option</option>
                }
            </select>
        </div>

        <div class="filter-field">
            <label for="statusFilter">Status</label>
            <select id="statusFilter" class="form-select" @bind="selectedStatus">
                <option value="">All</option>
                @foreach (var option in response?.Filters.Statuses ?? [])
                {
                    <option value="@option">@option</option>
                }
            </select>
        </div>

        <div class="filter-field">
            <label for="fromDate">From (UTC)</label>
            <input id="fromDate" class="form-control" type="date" @bind-value="fromDate" @bind-value:format="yyyy-MM-dd" />
        </div>

        <div class="filter-field">
            <label for="toDate">To (UTC)</label>
            <input id="toDate" class="form-control" type="date" @bind-value="toDate" @bind-value:format="yyyy-MM-dd" />
        </div>

        <div class="filter-field compact-input">
            <label for="pageSize">Page size</label>
            <select id="pageSize" class="form-select" @bind="pageSize">
                @foreach (var option in PageSizeOptions)
                {
                    <option value="@option">@option</option>
                }
            </select>
        </div>

        <div class="filter-field actions">
            <button class="btn btn-primary" @onclick="ApplyFiltersAsync" disabled="@isBusy">Apply filters</button>
        </div>
    </section>

    @if (isBusy && response is null)
    {
        <p>Loading games...</p>
    }
    else if (response is not null)
    {
        <section class="summary-panel">
            <div class="summary-card">
                <span class="summary-label">Filtered Games</span>
                <strong>@response.Summary.FilteredGames</strong>
            </div>
            <div class="summary-card">
                <span class="summary-label">Finished</span>
                <strong>@response.Summary.FinishedGames</strong>
            </div>
            <div class="summary-card">
                <span class="summary-label">Scheduled / Other</span>
                <strong>@response.Summary.ScheduledGames</strong>
            </div>
            <div class="summary-card">
                <span class="summary-label">Date Span</span>
                <strong>@FormatDateSpan(response.Summary.FirstGameUtc, response.Summary.LastGameUtc)</strong>
            </div>
        </section>

        <section class="table-section">
            <div class="section-head">
                <div>
                    <h2>Games</h2>
                    <p>Showing page @response.Page of @response.TotalPages, with @response.TotalCount matching games.</p>
                </div>
                <div class="pager">
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="PreviousPageAsync" disabled="@isBusy || response.Page <= 1">Previous</button>
                    <label class="page-jump" for="gamesPageInput">
                        <span>Page</span>
                        <input id="gamesPageInput" class="form-control form-control-sm" type="number" min="1" max="@response.TotalPages" @bind="requestedPage" @onkeydown="HandlePageInputKeyDown" />
                    </label>
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="GoToRequestedPageAsync" disabled="@isBusy">Go</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="NextPageAsync" disabled="@isBusy || response.Page >= response.TotalPages">Next</button>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle games-table">
                    <thead>
                        <tr>
                            <th>Date (local)</th>
                            <th>Country</th>
                            <th>League</th>
                            <th>Season</th>
                            <th>Matchup</th>
                            <th>Score</th>
                            <th>Status</th>
                            <th>Source</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (response.Games.Count == 0)
                        {
                            <tr>
                                <td colspan="9" class="empty-state">No games match the current filters.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var game in response.Games)
                            {
                                <tr>
                                    <td>@game.GameDateTimeUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>@game.Country</td>
                                    <td>@game.LeagueName</td>
                                    <td>@game.Season</td>
                                    <td>
                                        <div class="matchup">
                                            <span>@game.HomeTeam</span>
                                            <span class="vs">vs</span>
                                            <span>@game.AwayTeam</span>
                                        </div>
                                    </td>
                                    <td>@FormatScore(game)</td>
                                    <td><span class="status-pill @StatusClass(game.Status)">@game.Status</span></td>
                                    <td>@game.Source</td>
                                    <td>
                                        <div class="explain-action">
                                            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => LoadExplanationAsync(game.Id)" disabled="@IsExplanationLoading(game.Id)">
                                                @(IsExplanationLoading(game.Id) ? "Loading" : "Explain")
                                            </button>
                                            @if (HasExplanationError(game.Id))
                                            {
                                                <span class="explanation-error-indicator"
                                                      tabindex="0"
                                                      role="img"
                                                      aria-label="@explanationError"
                                                      data-tooltip="@explanationError"
                                                      title="@explanationError">
                                                    !
                                                </span>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

        </section>

        <GameEloExplanationPanel Explanation="selectedExplanation"
                                 IsLoading="isExplanationLoading"
                                 ErrorMessage="@explanationError"
                                 OnClose="CloseExplanation" />
    }
</div>

@code {
    private static readonly int[] PageSizeOptions = [25, 50, 100, 200];

    [SupplyParameterFromQuery(Name = "country")]
    public string? Country { get; set; }

    [SupplyParameterFromQuery(Name = "league")]
    public string? League { get; set; }

    [SupplyParameterFromQuery(Name = "season")]
    public string? Season { get; set; }

    [SupplyParameterFromQuery(Name = "status")]
    public string? Status { get; set; }

    [SupplyParameterFromQuery(Name = "team")]
    public string? Team { get; set; }

    [SupplyParameterFromQuery(Name = "search")]
    public string? Search { get; set; }

    [SupplyParameterFromQuery(Name = "from")]
    public DateTime? From { get; set; }

    [SupplyParameterFromQuery(Name = "to")]
    public DateTime? To { get; set; }

    [SupplyParameterFromQuery(Name = "page")]
    public int? Page { get; set; }

    [SupplyParameterFromQuery(Name = "pageSize")]
    public int? PageSize { get; set; }

    private GameBrowseResponse? response;
    private bool isBusy;
    private string? errorMessage;
    private string? selectedCountry;
    private string? selectedLeague;
    private string? selectedSeason;
    private string? selectedStatus;
    private string? team;
    private string? search;
    private DateTime? fromDate;
    private DateTime? toDate;
    private int page = 1;
    private int pageSize = 50;
    private int requestedPage = 1;
    private string? lastLoadedUri;
    private Guid? selectedExplanationGameId;
    private EloGameExplanationResponse? selectedExplanation;
    private bool isExplanationLoading;
    private string? explanationError;

    protected override async Task OnParametersSetAsync()
    {
        var currentUri = Navigation.Uri;
        if (currentUri == lastLoadedUri)
        {
            return;
        }

        selectedCountry = Country;
        selectedLeague = League;
        selectedSeason = Season;
        selectedStatus = Status;
        team = Team;
        search = Search;
        fromDate = From;
        toDate = To;
        page = Math.Max(1, Page ?? 1);
        pageSize = PageSizeOptions.Contains(PageSize ?? 0) ? PageSize!.Value : 50;
        requestedPage = page;
        lastLoadedUri = currentUri;

        await RefreshAsync();
    }

    private Task ApplyFiltersAsync()
    {
        NavigateToGames(1);
        return Task.CompletedTask;
    }

    private Task PreviousPageAsync()
    {
        NavigateToGames(Math.Max(1, (response?.Page ?? page) - 1));
        return Task.CompletedTask;
    }

    private Task NextPageAsync()
    {
        if (response is not null)
        {
            NavigateToGames(Math.Min(response.TotalPages, response.Page + 1));
        }

        return Task.CompletedTask;
    }

    private Task GoToRequestedPageAsync()
    {
        NavigateToGames(ClampRequestedPage(requestedPage, response?.TotalPages ?? 1));
        return Task.CompletedTask;
    }

    private async Task HandlePageInputKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            await GoToRequestedPageAsync();
        }
    }

    private Task ResetFiltersAsync()
    {
        selectedCountry = null;
        selectedLeague = null;
        selectedSeason = null;
        selectedStatus = null;
        team = null;
        search = null;
        fromDate = null;
        toDate = null;
        page = 1;
        pageSize = 50;
        NavigateToGames(1);
        return Task.CompletedTask;
    }

    private async Task RefreshAsync()
    {
        isBusy = true;
        errorMessage = null;

        try
        {
            response = await Http.GetFromJsonAsync<GameBrowseResponse>(BuildUri());
            if (response is not null)
            {
                page = response.Page;
                requestedPage = response.Page;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not load games: {ex.Message}";
        }
        finally
        {
            isBusy = false;
            StateHasChanged();
        }
    }

    private void NavigateToGames(int targetPage)
    {
        targetPage = ClampRequestedPage(targetPage, response?.TotalPages ?? targetPage);
        CloseExplanation();

        var query = new Dictionary<string, object?>
        {
            ["country"] = selectedCountry,
            ["league"] = selectedLeague,
            ["season"] = selectedSeason,
            ["status"] = selectedStatus,
            ["team"] = team,
            ["search"] = search,
            ["from"] = fromDate?.ToString("yyyy-MM-dd"),
            ["to"] = toDate?.ToString("yyyy-MM-dd"),
            ["page"] = targetPage > 1 ? targetPage : null,
            ["pageSize"] = pageSize != 50 ? pageSize : null
        };

        Navigation.NavigateTo(Navigation.GetUriWithQueryParameters("/games", query));
    }

    private string BuildUri()
    {
        var query = new List<string>
        {
            $"page={page}",
            $"pageSize={pageSize}"
        };

        Append(query, "country", selectedCountry);
        Append(query, "leagueName", selectedLeague);
        Append(query, "season", selectedSeason);
        Append(query, "status", selectedStatus);
        Append(query, "team", team);
        Append(query, "search", search);
        Append(query, "fromUtc", NormalizeDate(fromDate)?.ToString("O"));
        Append(query, "toUtc", NormalizeInclusiveDateEnd(toDate)?.ToString("O"));

        return $"api/games?{string.Join("&", query)}";
    }

    private async Task LoadExplanationAsync(Guid gameId)
    {
        selectedExplanationGameId = gameId;
        selectedExplanation = null;
        explanationError = null;
        isExplanationLoading = true;

        try
        {
            using var responseMessage = await Http.GetAsync($"api/elo/games/{gameId}/explanation");
            if (!responseMessage.IsSuccessStatusCode)
            {
                throw new InvalidOperationException(await ReadErrorMessageAsync(responseMessage));
            }

            selectedExplanation = await responseMessage.Content.ReadFromJsonAsync<EloGameExplanationResponse>();
            if (selectedExplanation is null)
            {
                throw new InvalidOperationException("The API returned an empty explanation.");
            }
        }
        catch (Exception ex)
        {
            explanationError = $"Could not load ELO explanation: {ex.Message}";
        }
        finally
        {
            isExplanationLoading = false;
        }
    }

    private bool IsExplanationLoading(Guid gameId)
        => isExplanationLoading && selectedExplanationGameId == gameId;

    private bool HasExplanationError(Guid gameId)
        => selectedExplanationGameId == gameId && !string.IsNullOrWhiteSpace(explanationError);

    private void CloseExplanation()
    {
        selectedExplanationGameId = null;
        selectedExplanation = null;
        explanationError = null;
        isExplanationLoading = false;
    }

    private static async Task<string> ReadErrorMessageAsync(HttpResponseMessage responseMessage)
    {
        var body = await responseMessage.Content.ReadAsStringAsync();
        if (string.IsNullOrWhiteSpace(body))
        {
            return responseMessage.ReasonPhrase ?? $"HTTP {(int)responseMessage.StatusCode}";
        }

        try
        {
            using var json = JsonDocument.Parse(body);
            if (json.RootElement.TryGetProperty("detail", out var detail) && detail.ValueKind == JsonValueKind.String)
            {
                return detail.GetString() ?? body;
            }

            if (json.RootElement.TryGetProperty("title", out var title) && title.ValueKind == JsonValueKind.String)
            {
                return title.GetString() ?? body;
            }

            if (json.RootElement.ValueKind == JsonValueKind.String)
            {
                return json.RootElement.GetString() ?? body;
            }
        }
        catch (JsonException)
        {
        }

        return body;
    }

    private static int ClampRequestedPage(int value, int totalPages)
        => Math.Clamp(value, 1, Math.Max(1, totalPages));

    private static void Append(List<string> query, string key, string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return;
        }

        query.Add($"{Uri.EscapeDataString(key)}={Uri.EscapeDataString(value)}");
    }

    private static DateTime? NormalizeDate(DateTime? value)
        => value.HasValue
            ? DateTime.SpecifyKind(value.Value.Date, DateTimeKind.Utc)
            : null;

    private static DateTime? NormalizeInclusiveDateEnd(DateTime? value)
        => NormalizeDate(value)?.AddDays(1).AddTicks(-1);

    private static string FormatScore(GameListItem game)
        => game.HomeScore.HasValue && game.AwayScore.HasValue
            ? $"{game.HomeScore}-{game.AwayScore}"
            : "-";

    private static string FormatDateSpan(DateTime? first, DateTime? last)
    {
        if (first is null || last is null)
        {
            return "-";
        }

        return $"{first.Value.ToLocalTime():yyyy-MM-dd} to {last.Value.ToLocalTime():yyyy-MM-dd}";
    }

    private static string StatusClass(string status)
        => status.Contains("finished", StringComparison.OrdinalIgnoreCase)
            ? "status-completed"
            : "status-empty";
}
