    private async Task RunBacktestAsync()
    {
        NormalizeScopeForEntitlement();

        if (scopeType == ModelLabScopeTypes.SelectedCompetitions && selectedCompetitionIds.Count == 0)
        {
            errorMessage = "Choose at least one competition before running a backtest.";
            return;
        }

        if (scopeType == ModelLabScopeTypes.SingleCompetition && string.IsNullOrWhiteSpace(leagueName))
        {
            errorMessage = "Choose a competition before running a backtest.";
            return;
        }

        isRunning = true;
        errorMessage = null;

        try
        {
            var request = new ModelLabBacktestRequest(
                modelName,
                BuildParameterSet(),
                BuildRequestLeagueName(),
                DateTime.SpecifyKind(initializationFrom.Date, DateTimeKind.Utc),
                DateTime.SpecifyKind(initializationTo.Date, DateTimeKind.Utc).AddDays(1).AddTicks(-1),
                DateTime.SpecifyKind(scoredFrom.Date, DateTimeKind.Utc),
                DateTime.SpecifyKind(scoredTo.Date, DateTimeKind.Utc).AddDays(1).AddTicks(-1),
                scopeType,
                BuildRequestCompetitionIds());

            using var response = await Http.PostAsJsonAsync("api/model-lab/backtests", request);
            if (!response.IsSuccessStatusCode)
            {
                throw new InvalidOperationException(await ReadErrorMessageAsync(response));
            }

            result = await response.Content.ReadFromJsonAsync<ModelLabBacktestResponse>();
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not run backtest: {ex.Message}";
        }
        finally
        {
            isRunning = false;
        }
    }

    private async Task CreateStoredRunAsync()
    {
        NormalizeScopeForEntitlement();

        if (scopeType == ModelLabScopeTypes.SelectedCompetitions && selectedCompetitionIds.Count == 0)
        {
            errorMessage = "Choose at least one competition before saving a run.";
            return;
        }

        isSavingRun = true;
        errorMessage = null;
        modelStatusMessage = null;

        try
        {
            var model = await SaveCurrentModelForRunAsync();
            var request = new CreateModelLabRunRequest(
                model.Id,
                model.CurrentVersion.Id,
                DateTime.SpecifyKind(initializationFrom.Date, DateTimeKind.Utc),
                DateTime.SpecifyKind(initializationTo.Date, DateTimeKind.Utc).AddDays(1).AddTicks(-1),
                DateTime.SpecifyKind(scoredFrom.Date, DateTimeKind.Utc),
                DateTime.SpecifyKind(scoredTo.Date, DateTimeKind.Utc).AddDays(1).AddTicks(-1),
                scopeType,
                BuildRequestCompetitionIds());

            using var response = await Http.PostAsJsonAsync("api/model-lab/runs", request);
            if (!response.IsSuccessStatusCode)
            {
                throw new InvalidOperationException(await ReadErrorMessageAsync(response));
            }

            var createdRun = await response.Content.ReadFromJsonAsync<ModelLabRunCreateResponse>()
                ?? throw new InvalidOperationException("The saved run response was empty.");

            result = createdRun.Result;
            selectedModelIdText = model.Id.ToString();
            lastSavedRunSignature = BuildCurrentRunSignature();
            await LoadSavedModelsAsync();
            selectedModelIdText = model.Id.ToString();
            await LoadSavedRunsAsync();
            modelStatusMessage = $"Saved {model.Name} v{model.CurrentVersion.VersionNumber} and run {createdRun.RunId.ToString()[..8]}.";
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not save run: {ex.Message}";
        }
        finally
        {
            isSavingRun = false;
        }
    }

    private async Task<ModelLabModelDetailResponse> SaveCurrentModelForRunAsync()
    {
        HttpResponseMessage response;
        if (Guid.TryParse(selectedModelIdText, out var modelId))
        {
            response = await Http.PutAsJsonAsync($"api/model-lab/models/{modelId}", BuildSaveRequest());
        }
        else
        {
            response = await Http.PostAsJsonAsync("api/model-lab/models", BuildSaveRequest());
        }

        using (response)
        {
            if (!response.IsSuccessStatusCode)
            {
                throw new InvalidOperationException(await ReadErrorMessageAsync(response));
            }

            return await response.Content.ReadFromJsonAsync<ModelLabModelDetailResponse>()
                ?? throw new InvalidOperationException("The saved model response was empty.");
        }
    }

    private void ResetDefaults()
    {
        if (options is not null)
        {
            ApplyDefaults(options);
            selectedModelIdText = string.Empty;
            modelDescription = null;
            modelStatusMessage = null;
        }
    }

    private SaveModelLabModelRequest BuildSaveRequest()
        => new(
            modelName,
            modelDescription,
            leagueName ?? string.Empty,
            BuildParameterSet(),
            null);

    private ModelLabParameterSet BuildParameterSet()
        => new(
            baseRating,
            kFactor,
            homeAdvantageElo,
            probabilityScale,
            usesMarginAdjustment,
            usesMarginAdjustment ? pointsPerEloMargin : null,
            competitionWeight);

    private string BuildRequestLeagueName()
        => scopeType switch
        {
            ModelLabScopeTypes.AllCompetitions => "All competitions",
            ModelLabScopeTypes.SelectedCompetitions => selectedCompetitionIds.Count == 1
                ? AvailableCompetitions.FirstOrDefault(x => selectedCompetitionIds.Contains(x.Id))?.DisplayName ?? "Selected competition"
                : $"{selectedCompetitionIds.Count} competitions",
            _ => leagueName ?? string.Empty
        };

    private IReadOnlyCollection<Guid>? BuildRequestCompetitionIds()
        => scopeType == ModelLabScopeTypes.SelectedCompetitions
            ? selectedCompetitionIds.ToList()
            : null;

    private string BuildCurrentRunSignature()
    {
        var competitionIds = scopeType == ModelLabScopeTypes.SelectedCompetitions
            ? string.Join(",", selectedCompetitionIds.OrderBy(x => x))
            : string.Empty;
        var pointsPerMargin = usesMarginAdjustment
            ? pointsPerEloMargin.ToString("0.####")
            : string.Empty;

        return string.Join("|", [
            selectedModelIdText.Trim(),
            (modelName ?? string.Empty).Trim(),
            (modelDescription ?? string.Empty).Trim(),
            (leagueName ?? string.Empty).Trim(),
            scopeType,
            competitionIds,
            initializationFrom.Date.ToString("O"),
            initializationTo.Date.ToString("O"),
            scoredFrom.Date.ToString("O"),
            scoredTo.Date.ToString("O"),
            baseRating.ToString("0.####"),
            kFactor.ToString(),
            homeAdvantageElo.ToString("0.####"),
            probabilityScale.ToString("0.####"),
            usesMarginAdjustment.ToString(),
            pointsPerMargin,
            competitionWeight.ToString("0.####")
        ]);
    }

    private void ApplySavedModel(ModelLabModelDetailResponse model)
    {
        selectedModelIdText = model.Id.ToString();
        modelName = model.Name;
        modelDescription = model.Description;
        scopeType = ModelLabScopeTypes.SingleCompetition;
        leagueName = NormalizeLeagueForEntitlement(model.LeagueName);
        ApplyParameters(model.CurrentVersion.Parameters);
    }

    private void ApplyDefaults(ModelLabOptionsResponse response)
    {
        modelName = "Adjusted ELO experiment";
        modelDescription = null;
        scopeType = ModelLabScopeTypes.SingleCompetition;
        leagueName = NormalizeLeagueForEntitlement(response.Leagues.FirstOrDefault());
        selectedCompetitionIds = AvailableCompetitions
            .Take(2)
            .Where(x => x.Id != Guid.Empty)
            .Select(x => x.Id)
            .ToHashSet();
        ApplyParameters(response.Defaults);

        var last = response.LastGameUtc?.Date ?? DateTime.UtcNow.Date;
        scoredTo = last;
        scoredFrom = last.AddYears(-1).AddDays(1);
        initializationTo = scoredFrom.AddDays(-1);
        initializationFrom = initializationTo.AddYears(-2).AddDays(1);

        if (response.FirstGameUtc.HasValue && initializationFrom < response.FirstGameUtc.Value.Date)
        {
            initializationFrom = response.FirstGameUtc.Value.Date;
        }
    }

    private void ApplyParameters(ModelLabParameterSet parameters)
    {
        baseRating = parameters.BaseRating;
        kFactor = parameters.KFactor;
        homeAdvantageElo = parameters.HomeAdvantageElo;
        probabilityScale = parameters.ProbabilityScale;
        usesMarginAdjustment = parameters.UsesMarginAdjustment;
        pointsPerEloMargin = parameters.PointsPerEloMargin ?? 28m;
        competitionWeight = parameters.CompetitionWeight;
    }

    private string? NormalizeLeagueForEntitlement(string? requestedLeague)
    {
        NormalizeScopeForEntitlement();

        if (!string.IsNullOrWhiteSpace(entitlement?.RequiredLeagueName))
        {
            return entitlement.RequiredLeagueName;
        }

        return string.IsNullOrWhiteSpace(requestedLeague)
            ? AvailableLeagues.FirstOrDefault()
            : requestedLeague;
    }

    private void NormalizeScopeForEntitlement()
    {
        if (!CanUseMultiCompetitionScopes)
        {
            scopeType = ModelLabScopeTypes.SingleCompetition;
            selectedCompetitionIds = [];
        }
    }

    private ModelLabCompetitionOption? FindCompetition(string? displayName)
    {
        if (string.IsNullOrWhiteSpace(displayName))
        {
            return null;
        }

        return AvailableCompetitions.FirstOrDefault(x =>
            string.Equals(x.DisplayName, displayName, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(x.Name, displayName, StringComparison.OrdinalIgnoreCase));
    }

    private bool IsInfoPanelVisible(string key)
        => string.Equals(activeInfoPanel, key, StringComparison.Ordinal);

    private void ToggleInfoPanel(string key)
        => activeInfoPanel = IsInfoPanelVisible(key) ? null : key;

    private string CompareToBaseline()
    {
        if (result is null)
        {
            return string.Empty;
        }

        var diff = result.Summary.WinnerAccuracy - result.BaselineSummary.WinnerAccuracy;
        return diff switch
        {
            > 0 => $"+{diff:0.0} vs baseline",
            < 0 => $"{diff:0.0} vs baseline",
            _ => "even with baseline"
        };
    }

    private static async Task<string> ReadErrorMessageAsync(HttpResponseMessage response)
    {
        var body = await response.Content.ReadAsStringAsync();
        if (string.IsNullOrWhiteSpace(body))
        {
            return response.ReasonPhrase ?? $"HTTP {(int)response.StatusCode}";
        }

        try
        {
            using var json = JsonDocument.Parse(body);
            if (json.RootElement.ValueKind == JsonValueKind.String)
            {
                return json.RootElement.GetString() ?? body;
            }

            if (json.RootElement.TryGetProperty("title", out var title) && title.ValueKind == JsonValueKind.String)
            {
                return title.GetString() ?? body;
            }

            if (json.RootElement.TryGetProperty("message", out var message) && message.ValueKind == JsonValueKind.String)
            {
                return message.GetString() ?? body;
            }
        }
        catch (JsonException)
        {
        }

        return body;
    }

    private static string FormatMovement(decimal value)
        => value switch
        {
            > 0 => $"+{value:0}",
            < 0 => value.ToString("0"),
            _ => "0"
        };

    private static string MovementClass(decimal value)
        => value switch
        {
            > 0 => "movement-up",
            < 0 => "movement-down",
            _ => "movement-flat"
        };

    private static string FormatSigned(decimal value)
        => value > 0 ? $"+{value:0.0}" : value.ToString("0.0");
}
