        };

    private static string FormatSavedModelOption(ModelLabModelSummaryResponse model)
        => $"{model.Name} - v{model.CurrentVersion.VersionNumber}";

    private static string FormatRunDate(DateTime value)
        => value.ToLocalTime().ToString("yyyy-MM-dd HH:mm");

    private void OnScopeTypeChanged(ChangeEventArgs args)
    {
        scopeType = args.Value?.ToString() ?? ModelLabScopeTypes.SingleCompetition;
        if (!CanUseMultiCompetitionScopes)
        {
            scopeType = ModelLabScopeTypes.SingleCompetition;
        }

        if (scopeType == ModelLabScopeTypes.SelectedCompetitions && selectedCompetitionIds.Count == 0)
        {
            var selected = FindCompetition(leagueName) ?? AvailableCompetitions.FirstOrDefault();
            if (selected is not null && selected.Id != Guid.Empty)
            {
                selectedCompetitionIds.Add(selected.Id);
            }
        }
    }

    private void OnSelectedCompetitionsChanged(ChangeEventArgs args)
    {
        selectedCompetitionIds = args.Value switch
        {
            string[] values => values
                .Select(x => Guid.TryParse(x, out var id) ? id : Guid.Empty)
                .Where(x => x != Guid.Empty)
                .ToHashSet(),
            string value when Guid.TryParse(value, out var id) && id != Guid.Empty => [id],
            _ => []
        };
    }

    private async Task OnSelectedModelChangedAsync(ChangeEventArgs args)
    {
        selectedModelIdText = args.Value?.ToString() ?? string.Empty;
        modelStatusMessage = null;

        if (string.IsNullOrWhiteSpace(selectedModelIdText))
        {
            return;
        }

        await LoadSelectedModelAsync();
    }

    private async Task LoadSavedModelsAsync()
    {
        if (!CanSaveModels)
        {
            savedModels = [];
            selectedModelIdText = string.Empty;
            modelStatusMessage = "Sign in to save models.";
            return;
        }

        isLoadingModels = true;
        modelStatusMessage = null;

        try
        {
            using var response = await Http.GetAsync("api/model-lab/models");
            if (response.StatusCode is HttpStatusCode.Unauthorized or HttpStatusCode.Forbidden)
            {
                savedModels = [];
                selectedModelIdText = string.Empty;
                modelStatusMessage = "Sign in to save and load models.";
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                throw new InvalidOperationException(await ReadErrorMessageAsync(response));
            }

            savedModels = await response.Content.ReadFromJsonAsync<List<ModelLabModelSummaryResponse>>() ?? [];
        }
        catch (Exception ex)
        {
            modelStatusMessage = $"Could not load saved models: {ex.Message}";
        }
        finally
        {
            isLoadingModels = false;
        }
    }

    private async Task LoadSavedRunsAsync()
    {
        if (!CanSaveModels)
        {
            savedRuns = [];
            return;
        }

        isLoadingRuns = true;

        try
        {
            using var response = await Http.GetAsync("api/model-lab/runs?take=5");
            if (!response.IsSuccessStatusCode)
            {
                throw new InvalidOperationException(await ReadErrorMessageAsync(response));
            }

            savedRuns = await response.Content.ReadFromJsonAsync<List<ModelLabRunSummaryResponse>>() ?? [];
        }
        catch (Exception ex)
        {
            modelStatusMessage = $"Could not load saved runs: {ex.Message}";
        }
        finally
        {
            isLoadingRuns = false;
        }
    }

    private async Task DeleteSavedRunAsync(Guid runId)
    {
        if (confirmingDeleteRunId != runId)
        {
            confirmingDeleteRunId = runId;
            return;
        }

        deletingRunId = runId;
        errorMessage = null;
        modelStatusMessage = null;

        try
        {
            using var response = await Http.DeleteAsync($"api/model-lab/runs/{runId}");
            if (!response.IsSuccessStatusCode)
            {
                throw new InvalidOperationException(await ReadErrorMessageAsync(response));
            }

            if (result?.RunId == runId)
            {
                result = null;
                lastSavedRunSignature = null;
            }

            savedRuns = savedRuns.Where(x => x.Id != runId).ToList();
            confirmingDeleteRunId = null;
            modelStatusMessage = $"Deleted run {runId.ToString()[..8]}.";
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not delete run: {ex.Message}";
        }
        finally
        {
            deletingRunId = null;
        }
    }

    private async Task LoadSelectedModelAsync()
    {
        if (!CanSaveModels)
        {
            modelStatusMessage = "Sign in to save models.";
            return;
        }

        if (!Guid.TryParse(selectedModelIdText, out var modelId))
        {
            return;
        }

        isSavingModel = true;
        modelStatusMessage = null;

        try
        {
            using var response = await Http.GetAsync($"api/model-lab/models/{modelId}");
            if (!response.IsSuccessStatusCode)
            {
                throw new InvalidOperationException(await ReadErrorMessageAsync(response));
            }

            var model = await response.Content.ReadFromJsonAsync<ModelLabModelDetailResponse>()
                ?? throw new InvalidOperationException("The saved model response was empty.");
            ApplySavedModel(model);
            modelStatusMessage = $"Loaded {model.Name} v{model.CurrentVersion.VersionNumber}.";
        }
        catch (Exception ex)
        {
            modelStatusMessage = $"Could not load saved model: {ex.Message}";
        }
        finally
        {
            isSavingModel = false;
        }
    }

    private async Task SaveNewModelAsync()
    {
        if (!CanSaveModels)
        {
            modelStatusMessage = "Sign in to save models.";
            return;
        }

        isSavingModel = true;
        modelStatusMessage = null;

        try
        {
            using var response = await Http.PostAsJsonAsync("api/model-lab/models", BuildSaveRequest());
            if (!response.IsSuccessStatusCode)
            {
                throw new InvalidOperationException(await ReadErrorMessageAsync(response));
            }

            var model = await response.Content.ReadFromJsonAsync<ModelLabModelDetailResponse>()
                ?? throw new InvalidOperationException("The saved model response was empty.");
            selectedModelIdText = model.Id.ToString();
            ApplySavedModel(model);
            await LoadSavedModelsAsync();
            selectedModelIdText = model.Id.ToString();
            modelStatusMessage = $"Saved {model.Name} v{model.CurrentVersion.VersionNumber}.";
        }
        catch (Exception ex)
        {
            modelStatusMessage = $"Could not save model: {ex.Message}";
        }
        finally
        {
            isSavingModel = false;
        }
    }

