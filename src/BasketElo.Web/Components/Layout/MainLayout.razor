@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main class="app-main">
        <header class="top-row">
            <div class="top-context">
                <span class="workspace-label">Basketball ratings workspace</span>
                <span class="workspace-dot"></span>
                <span>Adjusted ELO, backfill operations, and model review</span>
            </div>
            <nav class="quick-links" aria-label="Quick links">
                <a href="rankings">Rankings</a>
                <a href="model-lab">Model Lab</a>
                <AuthorizeView Roles="admin">
                    <Authorized>
                        <a href="games">Games</a>
                    </Authorized>
                </AuthorizeView>
            </nav>
            <AuthStatus />
        </header>

        <article class="content">
            @Body
        </article>

        <footer class="data-attribution">
            Historical NBA game data from
            <a href="https://github.com/fivethirtyeight/data/tree/4c1ff5e3aef1816ae04af63218015066e186c147/nba-elo"
               target="_blank"
               rel="noopener noreferrer">FiveThirtyEight</a>, licensed under
            <a href="https://creativecommons.org/licenses/by/4.0/"
               target="_blank"
               rel="noopener noreferrer">CC BY 4.0</a>.
        </footer>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">x</a>
</div>
