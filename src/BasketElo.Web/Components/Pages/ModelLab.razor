@page "/model-lab"
@rendermode InteractiveServer
@using System.Net
@using System.Net.Http.Json
@using System.Text.Json
@using BasketElo.Domain.Elo
@using BasketElo.Infrastructure.Identity
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Options
@inject HttpClient Http
@inject IOptions<AuthOptions> AuthOptions

<PageTitle>Model Lab - Basket ELO</PageTitle>

<div class="model-lab-page">
    <section class="lab-hero">
        <div>
            <p class="eyebrow">Model Lab</p>
            <h1>Build a basketball rating model</h1>
            <p class="intro">Tune the ELO rules, scope a historical test to one league, and see how the model performs against real results.</p>
        </div>

        @if (result is not null)
        {
            <div class="score-card">
                <span>Model score</span>
                <strong>@result.Summary.WinnerAccuracy.ToString("0.0")%</strong>
                <small>@CompareToBaseline()</small>
            </div>
        }
    </section>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger" role="alert">@errorMessage</div>
    }

    @if (isLoadingOptions)
    {
        <section class="loading-panel">Loading Model Lab...</section>
    }
    else if (options is not null)
    {
        <section class="lab-workbench">
            <div class="model-panel">
                <div class="section-head">
                    <div>
                        <h2>Model</h2>
                        <p>These parameters define how the system predicts and updates ratings.</p>
                    </div>
                </div>

                <div class="saved-model-panel">
                    <div class="saved-model-row">
                        <div class="filter-field saved-model-select">
                            <label for="savedModel">Saved model</label>
                            <select id="savedModel" class="form-select" value="@selectedModelIdText" @onchange="OnSelectedModelChangedAsync" disabled="@(isLoadingModels || savedModels.Count == 0)">
                                <option value="">@SavedModelPlaceholder</option>
                                @foreach (var savedModel in savedModels)
                                {
                                    <option value="@savedModel.Id">@FormatSavedModelOption(savedModel)</option>
                                }
                            </select>
                        </div>

                        <div class="saved-model-actions">
                            <button type="button" class="btn btn-outline-secondary" @onclick="LoadSelectedModelAsync" disabled="@(!CanUseSelectedModel)">Load</button>
                            <button type="button" class="btn btn-primary" @onclick="SaveNewModelAsync" disabled="@(!CanSaveModels || isSavingModel)">Save new</button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="UpdateSelectedModelAsync" disabled="@(!CanUseSelectedModel)">Update</button>
                            <button type="button" class="btn btn-outline-danger" @onclick="ArchiveSelectedModelAsync" disabled="@(!CanUseSelectedModel)">Archive</button>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(modelStatusMessage))
                    {
                        <p class="model-status">@modelStatusMessage</p>
                    }
                    else if (!CanSaveModels)
                    {
                        <p class="model-status">Sign in to save models. You can still run temporary backtests without saving.</p>
                    }
                </div>

                <div class="control-grid">
                    <div class="filter-field wide">
                        <div class="label-with-info">
                            <label for="modelName">Name</label>
                            <button type="button"
                                    class="info-button"
                                    aria-expanded='@IsInfoPanelVisible("modelName")'
                                    aria-controls="modelNameInfo"
                                    title="Model name context"
                                    @onclick='() => ToggleInfoPanel("modelName")'>
                                i
                            </button>
                        </div>
                        <input id="modelName" class="form-control" @bind="modelName" maxlength="80" />
                        @if (IsInfoPanelVisible("modelName"))
                        {
                            <div id="modelNameInfo" class="info-panel">
                                <p>This is only a label for the experiment you are running. It does not affect ratings, probability, or margin calculations.</p>
                            </div>
                        }
                    </div>

                    <div class="filter-field wide">
                        <label for="modelDescription">Description</label>
                        <textarea id="modelDescription" class="form-control" rows="2" @bind="modelDescription" maxlength="1000"></textarea>
                    </div>

                    <div class="filter-field">
                        <div class="label-with-info">
                            <label for="baseRating">Base rating</label>
                            <button type="button"
                                    class="info-button"
                                    aria-expanded='@IsInfoPanelVisible("baseRating")'
                                    aria-controls="baseRatingInfo"
                                    title="Base rating context"
                                    @onclick='() => ToggleInfoPanel("baseRating")'>
                                i
                            </button>
                        </div>
                        <input id="baseRating" class="form-control" type="number" min="500" max="2500" step="10" @bind="baseRating" />
                        @if (IsInfoPanelVisible("baseRating"))
                        {
                            <div id="baseRatingInfo" class="info-panel">
                                <p>New teams start here before they have any games in the simulation. Changing this mostly shifts the whole league up or down unless teams enter the model at different times.</p>
                            </div>
                        }
                    </div>

                    <div class="filter-field">
                        <div class="label-with-info">
                            <label for="kFactor">K factor</label>
                            <button type="button"
                                    class="info-button"
                                    aria-expanded='@IsInfoPanelVisible("kFactor")'
                                    aria-controls="kFactorInfo"
                                    title="K factor context"
                                    @onclick='() => ToggleInfoPanel("kFactor")'>
                                i
                            </button>
                        </div>
                        <input id="kFactor" class="form-control" type="number" min="1" max="100" step="1" @bind="kFactor" />
                        @if (IsInfoPanelVisible("kFactor"))
                        {
                            <div id="kFactorInfo" class="info-panel">
                                <p>This controls how quickly ratings move after each game. Higher values react faster to recent results, but can make ratings noisier.</p>
                            </div>
                        }
                    </div>

                    <div class="filter-field">
                        <div class="label-with-info">
                            <label for="homeAdvantage">Home advantage</label>
                            <button type="button"
                                    class="info-button"
                                    aria-expanded='@IsInfoPanelVisible("homeAdvantage")'
                                    aria-controls="homeAdvantageInfo"
                                    title="Home advantage context"
                                    @onclick='() => ToggleInfoPanel("homeAdvantage")'>
                                i
                            </button>
                        </div>
                        <input id="homeAdvantage" class="form-control" type="number" min="-200" max="300" step="5" @bind="homeAdvantageElo" />
                        @if (IsInfoPanelVisible("homeAdvantage"))
                        {
                            <div id="homeAdvantageInfo" class="info-panel">
                                <p>This many ELO points are added to the home team before calculating win probability, expected margin, and the rating update.</p>
                            </div>
                        }
                    </div>

                    <div class="filter-field wide">
                        <div class="label-with-info">
                            <label for="probabilityScale">Probability scale</label>
                            <button type="button"
                                    class="info-button"
                                    aria-expanded='@IsInfoPanelVisible("probabilityScale")'
                                    aria-controls="probabilityScaleInfo"
                                    title="Probability scale context"
                                    @onclick='() => ToggleInfoPanel("probabilityScale")'>
                                i
                            </button>
                        </div>
                        <input id="probabilityScale" class="form-control" type="number" min="200" max="800" step="25" @bind="probabilityScale" />
                        @if (IsInfoPanelVisible("probabilityScale"))
                        {
                            <div id="probabilityScaleInfo" class="info-panel">
                                <p>
                                    This controls how quickly ELO difference turns into win probability. Smaller values make the model more confident; larger values keep predictions closer to 50%.
                                </p>
                                <p>
                                    For the current game, win probability uses the classic ELO curve from rating difference. It does not come directly from the expected point margin.
                                </p>
                                <p>
                                    Classic chess ELO uses 400, where a 400-point gap means about a 91% expected score. Basketball may calibrate near 400, but noisy data or volatile leagues may fit better around 450-550.
                                </p>
                                <p>
                                    Use Brier score and log loss to judge this parameter. Winner accuracy only checks which side is above 50%, so it will miss probability calibration issues.
                                </p>
                            </div>
                        }
                    </div>

                    <div class="filter-field">
                        <div class="label-with-info">
                            <label for="competitionWeight">Competition weight</label>
                            <button type="button"
                                    class="info-button"
                                    aria-expanded='@IsInfoPanelVisible("competitionWeight")'
                                    aria-controls="competitionWeightInfo"
                                    title="Competition weight context"
                                    @onclick='() => ToggleInfoPanel("competitionWeight")'>
                                i
                            </button>
                        </div>
                        <input id="competitionWeight" class="form-control" type="number" min="0.1" max="3" step="0.05" @bind="competitionWeight" />
                        @if (IsInfoPanelVisible("competitionWeight"))
                        {
                            <div id="competitionWeightInfo" class="info-panel">
                                <p>This multiplies rating movement after the game. Use it to model competitions where results should count more or less than the default.</p>
                            </div>
                        }
                    </div>

                    <div class="filter-field">
                        <div class="label-with-info">
                            <label class="toggle-field" for="usesMargin">
                                <input id="usesMargin" type="checkbox" @bind="usesMarginAdjustment" />
                                <span>Margin adjustment</span>
                            </label>
                            <button type="button"
                                    class="info-button"
                                    aria-expanded='@IsInfoPanelVisible("usesMargin")'
                                    aria-controls="usesMarginInfo"
                                    title="Margin adjustment context"
                                    @onclick='() => ToggleInfoPanel("usesMargin")'>
                                i
                            </button>
                        </div>
                        @if (IsInfoPanelVisible("usesMargin"))
                        {
                            <div id="usesMarginInfo" class="info-panel">
                                <p>When enabled, the model compares the actual margin to the expected margin and boosts or dampens the ELO update. Blowouts can move ratings more than narrow wins.</p>
                            </div>
                        }
                    </div>

                    <div class="filter-field">
                        <div class="label-with-info">
                            <label for="pointScale">Point margin scale</label>
                            <button type="button"
                                    class="info-button"
                                    aria-expanded='@IsInfoPanelVisible("pointScale")'
                                    aria-controls="pointScaleInfo"
                                    title="Point margin scale context"
                                    @onclick='() => ToggleInfoPanel("pointScale")'>
                                i
                            </button>
                        </div>
                        <input id="pointScale" class="form-control" type="number" min="5" max="100" step="1" @bind="pointsPerEloMargin" disabled="@(!usesMarginAdjustment)" />
                        @if (IsInfoPanelVisible("pointScale"))
                        {
                            <div id="pointScaleInfo" class="info-panel">
                                <p>This translates ELO difference into expected point margin. With 28, a 140-point ELO gap equals about 5 expected points.</p>
                                <p>Smaller values make the same ELO gap imply a larger spread. Larger values make expected margins more conservative.</p>
                                <p>This affects expected margin and margin-adjusted rating updates. Those rating updates can change future win probabilities, but the current game's probability still uses the probability scale above.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="model-panel">
                <div class="section-head">
                    <div>
                        <h2>Backtest</h2>
                        <p>Initialization builds starting ratings. The scored window measures prediction quality.</p>
                    </div>
                </div>

                <div class="control-grid">
                    <div class="filter-field wide">
                        <div class="label-with-info">
                            <label for="leagueName">League</label>
                            <button type="button"
                                    class="info-button"
                                    aria-expanded='@IsInfoPanelVisible("leagueName")'
                                    aria-controls="leagueNameInfo"
                                    title="League context"
                                    @onclick='() => ToggleInfoPanel("leagueName")'>
                                i
                            </button>
                        </div>
                        <select id="leagueName" class="form-select" @bind="leagueName">
                            @foreach (var league in AvailableLeagues)
                            {
                                <option value="@league">@league</option>
                            }
                        </select>
                        @if (IsInfoPanelVisible("leagueName"))
                        {
                            <div id="leagueNameInfo" class="info-panel">
                                <p>The backtest runs inside one league at a time. That keeps model comparisons cleaner because schedule strength, scoring style, and data coverage can vary by league.</p>
                            </div>
                        }
                        <p class="field-note">@LeagueAccessNote</p>
                    </div>

                    <div class="filter-field">
                        <div class="label-with-info">
                            <label for="initFrom">Init from</label>
                            <button type="button"
                                    class="info-button"
                                    aria-expanded='@IsInfoPanelVisible("initFrom")'
                                    aria-controls="initFromInfo"
                                    title="Initialization start context"
                                    @onclick='() => ToggleInfoPanel("initFrom")'>
                                i
                            </button>
                        </div>
                        <input id="initFrom" class="form-control" type="date" @bind-value="initializationFrom" @bind-value:format="yyyy-MM-dd" />
                        @if (IsInfoPanelVisible("initFrom"))
                        {
                            <div id="initFromInfo" class="info-panel">
                                <p>The initialization window builds ratings before scoring begins. Earlier starts give teams more history, but may include older team strength.</p>
                            </div>
                        }
                    </div>

                    <div class="filter-field">
                        <div class="label-with-info">
                            <label for="initTo">Init to</label>
                            <button type="button"
                                    class="info-button"
                                    aria-expanded='@IsInfoPanelVisible("initTo")'
                                    aria-controls="initToInfo"
                                    title="Initialization end context"
                                    @onclick='() => ToggleInfoPanel("initTo")'>
                                i
                            </button>
                        </div>
                        <input id="initTo" class="form-control" type="date" @bind-value="initializationTo" @bind-value:format="yyyy-MM-dd" />
                        @if (IsInfoPanelVisible("initTo"))
                        {
                            <div id="initToInfo" class="info-panel">
                                <p>Games up to this date update ratings but do not count in the reported backtest metrics.</p>
                            </div>
                        }
                    </div>

                    <div class="filter-field">
                        <div class="label-with-info">
                            <label for="scoredFrom">Score from</label>
                            <button type="button"
                                    class="info-button"
                                    aria-expanded='@IsInfoPanelVisible("scoredFrom")'
                                    aria-controls="scoredFromInfo"
                                    title="Scored start context"
                                    @onclick='() => ToggleInfoPanel("scoredFrom")'>
                                i
                            </button>
                        </div>
                        <input id="scoredFrom" class="form-control" type="date" @bind-value="scoredFrom" @bind-value:format="yyyy-MM-dd" />
                        @if (IsInfoPanelVisible("scoredFrom"))
                        {
                            <div id="scoredFromInfo" class="info-panel">
                                <p>From this date onward, predictions are recorded before each game updates ratings. These games drive winner accuracy, Brier score, log loss, and margin error.</p>
                            </div>
                        }
                    </div>

                    <div class="filter-field">
                        <div class="label-with-info">
                            <label for="scoredTo">Score to</label>
                            <button type="button"
                                    class="info-button"
                                    aria-expanded='@IsInfoPanelVisible("scoredTo")'
                                    aria-controls="scoredToInfo"
                                    title="Scored end context"
                                    @onclick='() => ToggleInfoPanel("scoredTo")'>
                                i
                            </button>
                        </div>
                        <input id="scoredTo" class="form-control" type="date" @bind-value="scoredTo" @bind-value:format="yyyy-MM-dd" />
                        @if (IsInfoPanelVisible("scoredTo"))
                        {
                            <div id="scoredToInfo" class="info-panel">
                                <p>This closes the scoring window. Use the same scored window when comparing models so metric changes come from parameters, not a different sample.</p>
                            </div>
                        }
                    </div>

                    <div class="run-actions">
                        <button type="button" class="btn btn-primary" @onclick="RunBacktestAsync" disabled="@isRunning">
                            @(isRunning ? "Running..." : "Run backtest")
                        </button>
                        <button type="button" class="btn btn-outline-secondary" @onclick="ResetDefaults" disabled="@isRunning">Reset</button>
                    </div>
                </div>
            </div>
        </section>

        @if (result is not null)
        {
            <section class="result-summary">
                <div>
                    <span>Scored games</span>
                    <strong>@result.Summary.ScoredGames</strong>
                    <small>@result.ScoredWindow.Games games in window</small>
                </div>
                <div>
                    <span>Winner accuracy</span>
                    <strong>@result.Summary.WinnerAccuracy.ToString("0.0")%</strong>
                    <small>Baseline @result.BaselineSummary.WinnerAccuracy.ToString("0.0")%</small>
                </div>
                <div>
                    <span>Brier score</span>
                    <strong>@result.Summary.BrierScore.ToString("0.000")</strong>
                    <small>Lower is better</small>
                </div>
                <div>
                    <span>Avg margin error</span>
                    <strong>@result.Summary.AverageMarginError.ToString("0.0")</strong>
                    <small>Baseline @result.BaselineSummary.AverageMarginError.ToString("0.0")</small>
                </div>
            </section>

            <section class="result-grid">
                <div class="result-panel">
                    <div class="section-head compact">
                        <div>
                            <h2>Final ratings</h2>
                            <p>@result.LeagueName &middot; @result.ModelName</p>
                        </div>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle compact-table">
                            <thead>
                                <tr>
                                    <th>Rank</th>
                                    <th>Team</th>
                                    <th class="numeric">ELO</th>
                                    <th class="numeric">Games</th>
                                    <th class="numeric">Recent</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in result.Ratings.Take(25))
                                {
                                    <tr>
                                        <td class="rank-cell">#@row.Rank</td>
                                        <td>@row.TeamName</td>
                                        <td class="numeric rating">@row.Elo.ToString("0")</td>
                                        <td class="numeric">@row.GamesPlayed</td>
                                        <td class="numeric"><span class="@MovementClass(row.RecentMovement)">@FormatMovement(row.RecentMovement)</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="result-panel">
                    <div class="section-head compact">
                        <div>
                            <h2>Performance over time</h2>
                            <p>Monthly scoring inside the test window.</p>
                        </div>
                    </div>
                    <div class="period-list">
                        @foreach (var period in result.Periods)
                        {
                            <div>
                                <span>@period.Label</span>
                                <strong>@period.WinnerAccuracy.ToString("0.0")%</strong>
                                <small>@period.Games games &middot; @period.AverageMarginError.ToString("0.0") margin error</small>
                            </div>
                        }
                    </div>
                </div>
            </section>

            <section class="result-panel">
                <div class="section-head compact">
                    <div>
                        <h2>Biggest misses</h2>
                        <p>Games where the expected margin was furthest from reality.</p>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle compact-table">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Matchup</th>
                                <th>Score</th>
                                <th class="numeric">Home win prob.</th>
                                <th class="numeric">Expected margin</th>
                                <th class="numeric">Actual</th>
                                <th class="numeric">Error</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in result.BiggestMisses)
                            {
                                <tr>
                                    <td>@row.GameDateTimeUtc.ToLocalTime().ToString("yyyy-MM-dd")</td>
                                    <td>@row.HomeTeam vs @row.AwayTeam</td>
                                    <td>@row.HomeScore-@row.AwayScore</td>
                                    <td class="numeric">@row.PredictedHomeWinProbability.ToString("P0")</td>
                                    <td class="numeric">@FormatSigned(row.PredictedHomeMargin)</td>
                                    <td class="numeric">@FormatSigned(row.ActualHomeMargin)</td>
                                    <td class="numeric rating">@row.MarginError.ToString("0.0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }
    }
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private ModelLabOptionsResponse? options;
    private ModelLabEntitlementResponse? entitlement;
    private ModelLabBacktestResponse? result;
    private List<ModelLabModelSummaryResponse> savedModels = [];
    private bool isLoadingOptions = true;
    private bool isLoadingModels;
    private bool isRunning;
    private bool isSavingModel;
    private bool isRealSignedIn;
    private string? errorMessage;
    private string? modelStatusMessage;
    private string modelName = "My model";
    private string? modelDescription;
    private string selectedModelIdText = string.Empty;
    private string? leagueName;
    private decimal baseRating;
    private int kFactor;
    private decimal homeAdvantageElo;
    private decimal probabilityScale;
    private bool usesMarginAdjustment;
    private decimal pointsPerEloMargin;
    private decimal competitionWeight;
    private string? activeInfoPanel;
    private DateTime initializationFrom;
    private DateTime initializationTo;
    private DateTime scoredFrom;
    private DateTime scoredTo;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (AuthenticationStateTask is not null)
            {
                var authenticationState = await AuthenticationStateTask;
                isRealSignedIn = AuthOptions.Value.Enabled &&
                    authenticationState.User.Identity?.IsAuthenticated == true;
            }

            entitlement = await Http.GetFromJsonAsync<ModelLabEntitlementResponse>("api/model-lab/entitlement");
            options = await Http.GetFromJsonAsync<ModelLabOptionsResponse>("api/model-lab/options");
            if (options is not null)
            {
                ApplyDefaults(options);
            }

            if (CanSaveModels)
            {
                await LoadSavedModelsAsync();
            }
            else
            {
                modelStatusMessage = "Sign in to save models.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not load Model Lab options: {ex.Message}";
        }
        finally
        {
            isLoadingOptions = false;
        }
    }

    private string SavedModelPlaceholder
        => isLoadingModels ? "Loading saved models..." : "No saved model selected";

    private bool CanSaveModels => AuthOptions.Value.Enabled && isRealSignedIn;

    private bool CanUseSelectedModel
        => CanSaveModels && !isSavingModel && Guid.TryParse(selectedModelIdText, out _);

    private IReadOnlyCollection<string> AvailableLeagues
    {
        get
        {
            if (options is null)
            {
                return [];
            }

            if (string.IsNullOrWhiteSpace(entitlement?.RequiredLeagueName))
            {
                return options.Leagues;
            }

            var requiredLeague = entitlement.RequiredLeagueName;
            return options.Leagues
                .Where(x => string.Equals(x, requiredLeague, StringComparison.OrdinalIgnoreCase))
                .DefaultIfEmpty(requiredLeague)
                .ToList();
        }
    }

    private string LeagueAccessNote
        => entitlement?.PlanKey switch
        {
            "anonymous" => $"Anonymous users can run Model Lab backtests for {entitlement.RequiredLeagueName ?? "ACB"} only. Sign in to save models.",
            "free" => $"Free users can run and save Model Lab work for {entitlement.RequiredLeagueName ?? "ACB"} only.",
            "paid" => "Paid users can run and save models across all available leagues.",
            _ => string.IsNullOrWhiteSpace(entitlement?.RequiredLeagueName)
                ? "Paid users can run and save models across all available leagues."
                : $"Current plan users can run and save Model Lab work for {entitlement.RequiredLeagueName} only."
        };

    private string PlanLabel
        => entitlement?.PlanKey switch
        {
            "anonymous" => "Anonymous",
            "free" => "Free",
            "paid" => "Paid",
            _ => "Current plan"
        };

    private static string FormatSavedModelOption(ModelLabModelSummaryResponse model)
        => $"{model.Name} - v{model.CurrentVersion.VersionNumber}";

    private async Task OnSelectedModelChangedAsync(ChangeEventArgs args)
    {
        selectedModelIdText = args.Value?.ToString() ?? string.Empty;
        modelStatusMessage = null;

        if (string.IsNullOrWhiteSpace(selectedModelIdText))
        {
            return;
        }

        await LoadSelectedModelAsync();
    }

    private async Task LoadSavedModelsAsync()
    {
        if (!CanSaveModels)
        {
            savedModels = [];
            selectedModelIdText = string.Empty;
            modelStatusMessage = "Sign in to save models.";
            return;
        }

        isLoadingModels = true;
        modelStatusMessage = null;

        try
        {
            using var response = await Http.GetAsync("api/model-lab/models");
            if (response.StatusCode is HttpStatusCode.Unauthorized or HttpStatusCode.Forbidden)
            {
                savedModels = [];
                selectedModelIdText = string.Empty;
                modelStatusMessage = "Sign in to save and load models.";
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                throw new InvalidOperationException(await ReadErrorMessageAsync(response));
            }

            savedModels = await response.Content.ReadFromJsonAsync<List<ModelLabModelSummaryResponse>>() ?? [];
        }
        catch (Exception ex)
        {
            modelStatusMessage = $"Could not load saved models: {ex.Message}";
        }
        finally
        {
            isLoadingModels = false;
        }
    }

    private async Task LoadSelectedModelAsync()
    {
        if (!CanSaveModels)
        {
            modelStatusMessage = "Sign in to save models.";
            return;
        }

        if (!Guid.TryParse(selectedModelIdText, out var modelId))
        {
            return;
        }

        isSavingModel = true;
        modelStatusMessage = null;

        try
        {
            using var response = await Http.GetAsync($"api/model-lab/models/{modelId}");
            if (!response.IsSuccessStatusCode)
            {
                throw new InvalidOperationException(await ReadErrorMessageAsync(response));
            }

            var model = await response.Content.ReadFromJsonAsync<ModelLabModelDetailResponse>()
                ?? throw new InvalidOperationException("The saved model response was empty.");
            ApplySavedModel(model);
            modelStatusMessage = $"Loaded {model.Name} v{model.CurrentVersion.VersionNumber}.";
        }
        catch (Exception ex)
        {
            modelStatusMessage = $"Could not load saved model: {ex.Message}";
        }
        finally
        {
            isSavingModel = false;
        }
    }

    private async Task SaveNewModelAsync()
    {
