@page "/"
@page "/rankings"
@rendermode InteractiveServer
@using System.Globalization
@using BasketElo.Domain.Elo
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Basket ELO Rankings</PageTitle>

<div class="rankings-page">
    <section class="rankings-hero">
        <div>
            <p class="eyebrow">Basket ELO</p>
            <h1>Basketball power rankings</h1>
            <p class="intro">Current strength ratings across the imported basketball world, tuned for the public adjusted ELO ruleset.</p>
        </div>

        @if (response?.Summary is not null)
        {
            <div class="leader-strip" aria-label="Top ranked team">
                <span>Strongest right now</span>
                <strong>@(response.Summary.TopTeamName ?? "-")</strong>
                <small>@FormatRating(response.Summary.TopTeamElo)</small>
            </div>
        }
    </section>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger" role="alert">
            @errorMessage
        </div>
    }

    <section class="ranking-filters" aria-label="Ranking filters">
        <div class="filter-field wide">
            <label for="teamSearch">Team</label>
            <input id="teamSearch" class="form-control" @bind="teamSearch" @bind:event="oninput" placeholder="Search Real Madrid, Fenerbahce..." />
        </div>

        <div class="filter-field">
            <label for="countryFilter">Country</label>
            <select id="countryFilter" class="form-select" @bind="selectedCountry">
                <option value="">All countries</option>
                @foreach (var option in response?.Filters.Countries ?? [])
                {
                    <option value="@option">@option</option>
                }
            </select>
        </div>

        <div class="filter-field">
            <label for="competitionFilter">Competition</label>
            <select id="competitionFilter" class="form-select" @bind="selectedCompetition">
                <option value="">All competitions</option>
                @foreach (var option in response?.Filters.Competitions ?? [])
                {
                    <option value="@option">@option</option>
                }
            </select>
        </div>

        <div class="filter-field">
            <label for="seasonFilter">Season</label>
            <select id="seasonFilter" class="form-select" @bind="selectedSeason">
                <option value="">Any season</option>
                @foreach (var option in response?.Filters.Seasons ?? [])
                {
                    <option value="@option">@option</option>
                }
            </select>
        </div>

        <div class="filter-field">
            <label for="fromDate">From</label>
            <input id="fromDate" class="form-control" type="date" @bind-value="fromDate" @bind-value:format="yyyy-MM-dd" />
        </div>

        <div class="filter-field">
            <label for="toDate">To</label>
            <input id="toDate" class="form-control" type="date" @bind-value="toDate" @bind-value:format="yyyy-MM-dd" />
        </div>

        <div class="filter-field compact">
            <label for="minGames">Min games</label>
            <input id="minGames" class="form-control" type="number" min="0" max="999" @bind="minimumGames" />
        </div>

        <div class="filter-actions">
            <button class="btn btn-primary" @onclick="ApplyFiltersAsync" disabled="@isBusy">Apply</button>
            <button class="btn btn-outline-secondary" @onclick="ResetFiltersAsync" disabled="@isBusy">Reset</button>
        </div>
    </section>

    @if (isBusy && response is null)
    {
        <section class="loading-panel">Loading rankings...</section>
    }
    else if (response is not null)
    {
        <section class="ranking-summary">
            <div>
                <span>Rated teams</span>
                <strong>@response.Summary.RatedTeams</strong>
            </div>
            <div>
                <span>Showing</span>
                <strong>@response.Summary.FilteredTeams</strong>
            </div>
            <div>
                <span>Latest rated game</span>
                <strong>@FormatDate(response.Summary.LatestGameUtc)</strong>
            </div>
            <div>
                <span>Ruleset</span>
                <strong>@response.RulesetVersion</strong>
            </div>
        </section>

        @if (response.Rankings.Count > 0)
        {
            <section class="evolution-section">
                <div class="section-head">
                    <div>
                        <h2>ELO evolution</h2>
                        <p>@EvolutionContextLabel()</p>
                    </div>
                </div>

                <div class="evolution-chart" role="img" aria-label="ELO evolution for teams in the current ranking table">
                    @if (EvolutionSeries.Count < 1 || EvolutionSeries.All(x => x.Points.Count < 2))
                    {
                        <div class="empty-state">Not enough rated games for an evolution chart yet.</div>
                    }
                    else
                    {
                        <EloEvolutionChart Series="@BuildEvolutionChartSeries()" EnableRangeNavigation="true" />

                        <div class="evolution-legend legacy-links" aria-label="ELO evolution chart team links">
                            @foreach (var item in EvolutionSeries.Select((series, index) => new { series, index }))
                            {
                                <a href="@BuildTeamHref(item.series.TeamId)">
                                    <span style="background: @ChartColor(item.index)"></span>
                                    @item.series.TeamName
                                </a>
                            }
                        </div>
                    }
                </div>
            </section>
        }

        <section class="rankings-table-section">
            <div class="section-head">
                <div>
                    <h2>Ranking table</h2>
                    <p>@TableContextLabel()</p>
                </div>
                <div class="pager">
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="PreviousPageAsync" disabled="@isBusy || response.Page <= 1">Previous</button>
                    <label class="page-jump" for="rankingsPageInput">
                        <span>Page</span>
                        <input id="rankingsPageInput" class="form-control form-control-sm" type="number" min="1" max="@response.TotalPages" @bind="requestedPage" @onkeydown="HandlePageInputKeyDown" />
                    </label>
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="GoToRequestedPageAsync" disabled="@isBusy">Go</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="NextPageAsync" disabled="@isBusy || response.Page >= response.TotalPages">Next</button>
                </div>
            </div>

            <div class="table-responsive ranking-table-wrap">
                <table class="table table-hover align-middle ranking-table">
                    <thead>
                        <tr>
                            <th>Rank</th>
                            @if (response.Summary.IsFiltered)
                            {
                                <th>Global</th>
                            }
                            <th>Team</th>
                            <th>Country</th>
                            <th class="numeric">ELO</th>
                            <th class="numeric">Games</th>
                            <th class="numeric">Recent</th>
                            <th>Last game</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (response.Rankings.Count == 0)
                        {
                            <tr>
                                <td colspan="8" class="empty-state">No teams match the current filters.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var row in response.Rankings)
                            {
                                <tr class="team-row" tabindex="0" @onclick="() => OpenTeam(row.TeamId)" @onkeydown="args => OpenTeamFromKeyboard(args, row.TeamId)">
                                    <td class="rank-cell">#@row.Rank</td>
                                    @if (response.Summary.IsFiltered)
                                    {
                                        <td class="muted-rank">#@row.GlobalRank</td>
                                    }
                                    <td>
                                        <a class="team-link" href="@BuildTeamHref(row.TeamId)" @onclick:stopPropagation="true">@row.TeamName</a>
                                    </td>
                                    <td>@row.Country</td>
                                    <td class="numeric rating">@row.Elo.ToString("0")</td>
                                    <td class="numeric">@row.GamesPlayed</td>
                                    <td class="numeric">
                                        <span class="@MovementClass(row.RecentMovement)">@FormatMovement(row.RecentMovement)</span>
                                    </td>
                                    <td>@FormatDate(row.LastGameUtc)</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "country")]
    public string? Country { get; set; }

    [SupplyParameterFromQuery(Name = "competition")]
    public string? Competition { get; set; }

    [SupplyParameterFromQuery(Name = "season")]
    public string? Season { get; set; }

    [SupplyParameterFromQuery(Name = "from")]
    public DateTime? From { get; set; }

    [SupplyParameterFromQuery(Name = "to")]
    public DateTime? To { get; set; }

    [SupplyParameterFromQuery(Name = "minGames")]
    public int? MinGames { get; set; }

    [SupplyParameterFromQuery(Name = "team")]
    public string? Team { get; set; }

    [SupplyParameterFromQuery(Name = "page")]
    public int? Page { get; set; }

    private EloRankingsResponse? response;
    private EloRankingsEvolutionResponse? evolution;
    private EloRankingsResponse? evolutionRankings;
    private bool isBusy;
    private string? errorMessage;
    private string? selectedCountry;
    private string? selectedCompetition;
    private string? selectedSeason;
    private string? teamSearch;
    private DateTime? fromDate;
    private DateTime? toDate;
    private int minimumGames;
    private int page = 1;
    private int requestedPage = 1;
    private string? lastLoadedUri;

    protected override async Task OnParametersSetAsync()
    {
        var currentUri = Navigation.Uri;
        if (currentUri == lastLoadedUri)
        {
            return;
        }

        selectedCountry = Country;
        selectedCompetition = Competition;
        selectedSeason = Season;
        fromDate = From;
        toDate = To;
        minimumGames = Math.Max(0, MinGames ?? 0);
        teamSearch = Team;
        page = Math.Max(1, Page ?? 1);
        requestedPage = page;
        lastLoadedUri = currentUri;

        await RefreshAsync();
    }

    private Task ApplyFiltersAsync()
    {
        NavigateToRankings(1);
        return Task.CompletedTask;
    }

    private Task ResetFiltersAsync()
    {
        selectedCountry = null;
        selectedCompetition = null;
        selectedSeason = null;
        fromDate = null;
        toDate = null;
        minimumGames = 0;
        teamSearch = null;
        NavigateToRankings(1);
        return Task.CompletedTask;
    }

    private Task PreviousPageAsync()
    {
        NavigateToRankings(Math.Max(1, (response?.Page ?? page) - 1));
        return Task.CompletedTask;
    }

    private Task NextPageAsync()
    {
        if (response is not null)
        {
            NavigateToRankings(Math.Min(response.TotalPages, response.Page + 1));
        }

        return Task.CompletedTask;
    }

    private Task GoToRequestedPageAsync()
    {
        NavigateToRankings(ClampRequestedPage(requestedPage, response?.TotalPages ?? 1));
        return Task.CompletedTask;
    }

    private async Task HandlePageInputKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            await GoToRequestedPageAsync();
        }
    }

    private async Task RefreshAsync()
    {
        isBusy = true;
        errorMessage = null;

        try
        {
            response = await Http.GetFromJsonAsync<EloRankingsResponse>(BuildApiUri());
            if (response is not null)
            {
                page = response.Page;
                requestedPage = response.Page;
            }
            evolutionRankings = await FetchEvolutionRankingsAsync();
            evolution = await FetchEvolutionAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not load rankings: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }

    private void NavigateToRankings(int targetPage)
    {
        targetPage = ClampRequestedPage(targetPage, response?.TotalPages ?? targetPage);

        var query = new Dictionary<string, object?>
        {
            ["country"] = selectedCountry,
            ["competition"] = selectedCompetition,
            ["season"] = selectedSeason,
            ["from"] = fromDate?.ToString("yyyy-MM-dd"),
            ["to"] = toDate?.ToString("yyyy-MM-dd"),
            ["minGames"] = minimumGames > 0 ? minimumGames : null,
            ["team"] = teamSearch,
            ["page"] = targetPage > 1 ? targetPage : null
        };

        Navigation.NavigateTo(Navigation.GetUriWithQueryParameters("/rankings", query));
    }

    private static int ClampRequestedPage(int value, int totalPages)
        => Math.Clamp(value, 1, Math.Max(1, totalPages));

    private string BuildApiUri()
    {
        var query = new List<string>
        {
            "pageSize=50",
            $"page={page}"
        };

        Append(query, "country", selectedCountry);
        Append(query, "competition", selectedCompetition);
        Append(query, "season", selectedSeason);
        Append(query, "fromUtc", NormalizeDate(fromDate)?.ToString("O"));
        Append(query, "toUtc", NormalizeInclusiveDateEnd(toDate)?.ToString("O"));
        Append(query, "minGames", minimumGames > 0 ? minimumGames.ToString() : null);
        Append(query, "team", teamSearch);

        return $"api/elo/rankings?{string.Join("&", query)}";
    }

    private async Task<EloRankingsEvolutionResponse?> FetchEvolutionAsync()
    {
        if (evolutionRankings is null || evolutionRankings.Rankings.Count == 0)
        {
            return null;
        }

        return await Http.GetFromJsonAsync<EloRankingsEvolutionResponse>(BuildEvolutionApiUri());
    }

    private string BuildEvolutionApiUri()
    {
        var teamIds = string.Join(",", evolutionRankings?.Rankings.Take(20).Select(x => x.TeamId) ?? []);
        return $"api/elo/rankings/evolution?rulesetVersion={Uri.EscapeDataString(response?.RulesetVersion ?? string.Empty)}&teamIds={Uri.EscapeDataString(teamIds)}&pointsPerTeam=0";
    }

    private async Task<EloRankingsResponse?> FetchEvolutionRankingsAsync()
    {
        if (response is null || response.TotalCount == 0)
        {
            return null;
        }

        return await Http.GetFromJsonAsync<EloRankingsResponse>(BuildEvolutionRankingsApiUri());
    }

    private string BuildEvolutionRankingsApiUri()
    {
        var query = new List<string>
        {
            "pageSize=20",
            "page=1"
        };

        Append(query, "country", selectedCountry);
        Append(query, "competition", selectedCompetition);
        Append(query, "season", selectedSeason);
        Append(query, "fromUtc", NormalizeDate(fromDate)?.ToString("O"));
        Append(query, "toUtc", NormalizeInclusiveDateEnd(toDate)?.ToString("O"));
        Append(query, "minGames", minimumGames > 0 ? minimumGames.ToString() : null);
        Append(query, "team", teamSearch);

        return $"api/elo/rankings?{string.Join("&", query)}";
    }

    private string BuildTeamHref(Guid teamId)
    {
        var returnUrl = Navigation.ToBaseRelativePath(Navigation.Uri);
        return $"/teams/{teamId}?returnUrl={Uri.EscapeDataString(returnUrl)}";
    }

    private IReadOnlyList<EloTeamEvolutionSeries> EvolutionSeries
        => evolution?.Series
            .Where(x => evolutionRankings?.Rankings.Any(row => row.TeamId == x.TeamId) == true)
            .ToList() ?? [];

    private string EvolutionContextLabel()
        => response?.Summary.IsFiltered == true
            ? "Rating history for the top 20 teams in the current filtered result set."
            : "Rating history for the top 20 teams overall.";

    private string TableContextLabel()
    {
        if (response is null)
        {
            return string.Empty;
        }

        var rangeStart = response.TotalCount == 0 ? 0 : ((response.Page - 1) * response.PageSize) + 1;
        var rangeEnd = Math.Min(response.TotalCount, response.Page * response.PageSize);
        var scope = response.Summary.IsFiltered ? "filtered teams" : "rated teams";

        return $"Showing {rangeStart}-{rangeEnd} of {response.TotalCount} {scope}. Page {response.Page} of {response.TotalPages}.";
    }

    private IReadOnlyList<EloChartSeries> BuildEvolutionChartSeries()
        => EvolutionSeries
            .Select((series, index) => new EloChartSeries(
                series.TeamId,
                series.TeamName,
                ChartColor(index),
                series.Points
                    .OrderBy(point => point.GameDateTimeUtc)
                    .Select(point => new EloChartPoint(
                        point.GameDateTimeUtc,
                        point.Elo,
                        series.TeamName,
                        ChartColor(index)))
                    .ToList()))
            .ToList();

    private static string ChartColor(int index)
    {
        string[] colors =
        [
            "#1b6ec2",
            "#087443",
            "#b42318",
            "#8a4baf",
            "#b7791f",
            "#006d77",
            "#c2410c",
            "#3949ab",
            "#52796f",
            "#be185d",
            "#4d7c0f",
            "#7c2d12",
            "#0f766e",
            "#6d28d9",
            "#a16207",
            "#2563eb",
            "#15803d",
            "#9f1239",
            "#0369a1",
            "#854d0e"
        ];

        return colors[index % colors.Length];
    }

    private static void AppendLabel(List<string> labels, string? value)
    {
        if (!string.IsNullOrWhiteSpace(value))
        {
            labels.Add(value);
        }
    }

    private void OpenTeam(Guid teamId)
        => Navigation.NavigateTo(BuildTeamHref(teamId));

    private void OpenTeamFromKeyboard(KeyboardEventArgs args, Guid teamId)
    {
        if (args.Key is "Enter" or " ")
        {
            OpenTeam(teamId);
        }
    }

    private static void Append(List<string> query, string key, string? value)
    {
        if (!string.IsNullOrWhiteSpace(value))
        {
            query.Add($"{Uri.EscapeDataString(key)}={Uri.EscapeDataString(value)}");
        }
    }

    private static DateTime? NormalizeDate(DateTime? value)
        => value.HasValue
            ? DateTime.SpecifyKind(value.Value.Date, DateTimeKind.Utc)
            : null;

    private static DateTime? NormalizeInclusiveDateEnd(DateTime? value)
        => NormalizeDate(value)?.AddDays(1).AddTicks(-1);

    private static string FormatRating(decimal? value)
        => value.HasValue ? value.Value.ToString("0") : "-";

    private static string FormatDate(DateTime? value)
        => value.HasValue ? value.Value.ToLocalTime().ToString("MMM d, yyyy") : "-";

    private static string FormatMovement(decimal value)
        => value switch
        {
            > 0 => $"+{value:0}",
            < 0 => value.ToString("0"),
            _ => "0"
        };

    private static string MovementClass(decimal value)
        => value switch
        {
            > 0 => "movement-up",
            < 0 => "movement-down",
            _ => "movement-flat"
        };
}
