@using System.Globalization

<div class="elo-chart">
    @if (EnableRangeNavigation)
    {
        <div class="elo-chart-toolbar" aria-label="Chart range controls">
            <div class="elo-chart-controls">
                <div class="elo-chart-segment" aria-label="Chart sampling mode">
                    <button type="button" class="@SamplingButtonClass(EloChartSamplingMode.GameByGame)" @onclick="() => SetSamplingMode(EloChartSamplingMode.GameByGame)">Game snapshots</button>
                    <button type="button" class="@SamplingButtonClass(EloChartSamplingMode.Weekly)" @onclick="() => SetSamplingMode(EloChartSamplingMode.Weekly)">Weekly</button>
                    <button type="button" class="@SamplingButtonClass(EloChartSamplingMode.Monthly)" @onclick="() => SetSamplingMode(EloChartSamplingMode.Monthly)">Monthly</button>
                </div>
                <div class="elo-chart-range-buttons">
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ShowFullRange">Full span</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ShowRecentHalf">Recent half</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ShowRecentQuarter">Recent quarter</button>
                </div>
            </div>
            <span class="elo-chart-context">
                <span>@ChartContextLabel</span>
                <span class="elo-chart-refinement-slot" aria-live="polite">
                    @if (IsRefining)
                    {
                        <span class="spinner-border spinner-border-sm elo-chart-refinement-spinner" aria-hidden="true"></span>
                        <span class="visually-hidden">Refreshing chart detail</span>
                    }
                </span>
            </span>
        </div>
    }

    <RadzenChart class="elo-radzen-chart"
                 Style="@ChartStyle"
                 TooltipTolerance="40"
                 MouseMoveThrottle="25"
                 AllowZoom="@EnableRangeNavigation"
                 AllowPan="@EnableRangeNavigation"
                 @bind-Zoom="chartZoom"
                 @bind-ViewStart="viewStart"
                 @bind-ViewEnd="viewEnd"
                 ViewChange="@HandleViewChangeAsync">
        <RadzenChartTooltipOptions Shared="@SharedTooltip" Trigger="@TooltipTrigger" />
        <RadzenLegend Visible="@ShowLegend" Position="LegendPosition.Bottom" />

        @foreach (var series in DisplaySeries)
        {
            <RadzenLineSeries Data="@series.Points"
                              TItem="EloChartPoint"
                              CategoryProperty="@CategoryProperty"
                              ValueProperty="@nameof(EloChartPoint.Elo)"
                              Title="@series.TeamName"
                              Stroke="@series.Color"
                              StrokeWidth="3"
                              Smooth="@Smooth">
                <ChildContent>
                    <RadzenMarkers MarkerType="MarkerType.Circle" Size="2" Fill="@series.Color" Stroke="@series.Color" />
                </ChildContent>
                <TooltipTemplate Context="point">
                    <div class="elo-chart-tooltip" style="--active-team-color: @point.Color">
                        <div class="elo-chart-tooltip-team">
                            <span class="elo-chart-active-swatch"></span>
                            <strong>@point.TeamName</strong>
                        </div>
                        <span>@FormatDate(point.GameDateTimeUtc)</span>
                        <span>@point.Elo.ToString("0") ELO</span>
                        @if (point.EloDelta.HasValue)
                        {
                            <span>Change @FormatMovement(point.EloDelta.Value)</span>
                        }
                        @if (point.Rank.HasValue)
                        {
                            <span>Rank #@point.Rank</span>
                        }
                    </div>
                </TooltipTemplate>
            </RadzenLineSeries>
        }

        <RadzenCategoryAxis Formatter="@FormatCategoryAxis"
                            LabelAutoRotation="-35"
                            Min="@CategoryAxisMin"
                            Max="@CategoryAxisMax"
                            TickPlacement="@CategoryTickPlacement">
            <RadzenAxisCrosshair Visible="true" Label="true" Snap="true" Stroke="#6b7682" />
        </RadzenCategoryAxis>
        <RadzenValueAxis Formatter="@FormatEloAxis">
            <RadzenGridLines Visible="true" />
            <RadzenAxisCrosshair Visible="true" Label="true" Stroke="#9aa6b2" />
        </RadzenValueAxis>
    </RadzenChart>
</div>

@code {
    [Parameter]
    public IReadOnlyList<EloChartSeries> Series { get; set; } = [];

    [Parameter]
    public bool ShowLegend { get; set; } = true;

    [Parameter]
    public bool SharedTooltip { get; set; } = true;

    [Parameter]
    public bool EnableRangeNavigation { get; set; }

    [Parameter]
    public bool Smooth { get; set; }

    [Parameter]
    public int HeightPixels { get; set; } = 340;

    [Parameter]
    public long DataRevision { get; set; }

    [Parameter]
    public bool IsRefining { get; set; }

    [Parameter]
    public EventCallback<EloChartViewportRange> ViewportRefinementRequested { get; set; }

    [Parameter]
    public EventCallback FullRangeRequested { get; set; }

    private double chartZoom = 100;
    private double viewStart;
    private double viewEnd = 1;

    private EloChartSamplingMode samplingMode = EloChartSamplingMode.GameByGame;
    private IReadOnlyList<EloChartSeries> sourceSeries = [];
    private IReadOnlyList<EloChartSeries> displaySeries = [];
    private IReadOnlyList<EloChartPoint> allPoints = [];
    private IReadOnlyList<DateTime> activeDates = [];
    private long renderedDataRevision = -1;

    private string ChartStyle => $"height: {Math.Clamp(HeightPixels, 260, 900)}px";

    private string CategoryProperty => samplingMode == EloChartSamplingMode.GameByGame
        ? nameof(EloChartPoint.ActiveDateIndex)
        : nameof(EloChartPoint.GameDateTimeUtc);

    private object? CategoryAxisMin =>
        samplingMode == EloChartSamplingMode.GameByGame && activeDates.Count > 1
            ? 0d
            : null;

    private object? CategoryAxisMax =>
        samplingMode == EloChartSamplingMode.GameByGame && activeDates.Count > 1
            ? (double)(activeDates.Count - 1)
            : null;

    private TickPlacement CategoryTickPlacement =>
        samplingMode == EloChartSamplingMode.GameByGame
            ? TickPlacement.On
            : TickPlacement.Between;

    private ChartTooltipTrigger TooltipTrigger => SharedTooltip
        ? ChartTooltipTrigger.Axis
        : ChartTooltipTrigger.Point;

    private IReadOnlyList<EloChartSeries> SourceSeries
        => sourceSeries;

    private IReadOnlyList<EloChartSeries> DisplaySeries
        => displaySeries;

    private IReadOnlyList<EloChartPoint> AllPoints
        => allPoints;

    private string ChartContextLabel
    {
        get
        {
            var points = AllPoints;
            if (points.Count == 0)
            {
                return "No range";
            }

            var visibleRange = GetVisibleDateRange(viewStart, viewEnd);
            if (!visibleRange.HasValue)
            {
                return "No range";
            }

            return $"{SamplingLabel(samplingMode)}: {FormatDate(visibleRange.Value.FromUtc)} - {FormatDate(visibleRange.Value.ToUtc)}";
        }
    }

    protected override void OnParametersSet()
    {
        var dataChanged = renderedDataRevision != DataRevision;
        sourceSeries = Series
            .Select(series => series with
            {
                Points = series.Points
                    .OrderBy(point => point.GameDateTimeUtc)
                    .ToList()
            })
            .Where(x => x.Points.Count >= 2)
            .ToList();
        RebuildDisplaySeries();

        if (!EnableRangeNavigation || dataChanged)
        {
            ResetView();
        }

        renderedDataRevision = DataRevision;
    }

    private async Task ShowFullRange()
    {
        ResetView();
        if (FullRangeRequested.HasDelegate)
        {
            await FullRangeRequested.InvokeAsync();
        }
    }

    private Task ShowRecentHalf()
        => SetRecentRange(0.5, 200);

    private Task ShowRecentQuarter()
        => SetRecentRange(0.25, 400);

    private async Task SetRecentRange(double fraction, double zoom)
    {
        chartZoom = zoom;
        viewStart = 1 - fraction;
        viewEnd = 1;
        await RequestViewportRefinementAsync(viewStart, viewEnd);
    }

    private void SetSamplingMode(EloChartSamplingMode mode)
    {
        if (samplingMode == mode)
        {
            return;
        }

        samplingMode = mode;
        RebuildDisplaySeries();
        ResetView();
    }

    private void RebuildDisplaySeries()
    {
        var sampledSeries = sourceSeries
            .Select(series => series with
            {
                Points = SamplePoints(series.Points, samplingMode)
            })
            .Where(x => x.Points.Count >= 2)
            .ToList();

        if (samplingMode == EloChartSamplingMode.GameByGame)
        {
            activeDates = sampledSeries
                .SelectMany(series => series.Points)
                .Select(point => point.GameDateTimeUtc.Date)
                .Distinct()
                .OrderBy(date => date)
                .ToList();
            var activeDateIndexes = activeDates
                .Select((date, index) => new { date, index })
                .ToDictionary(item => item.date, item => item.index);

            displaySeries = sampledSeries
                .Select(series => series with
                {
                    Points = series.Points
                        .Select(point => point with
                        {
                            ActiveDateIndex = activeDateIndexes[point.GameDateTimeUtc.Date]
                        })
                        .ToList()
                })
                .ToList();
        }
        else
        {
            activeDates = [];
            displaySeries = sampledSeries;
        }

        allPoints = displaySeries
            .SelectMany(x => x.Points)
            .OrderBy(x => x.GameDateTimeUtc)
            .ToList();
    }

    private async Task HandleViewChangeAsync(ChartViewChangeEventArgs args)
    {
        chartZoom = args.Zoom;
        viewStart = args.ViewStart;
        viewEnd = args.ViewEnd;
        await RequestViewportRefinementAsync(args.ViewStart, args.ViewEnd);
    }

    private async Task RequestViewportRefinementAsync(double requestedStart, double requestedEnd)
    {
        if (!ViewportRefinementRequested.HasDelegate || sourceSeries.Count == 0)
        {
            return;
        }

        var fullRange = GetVisibleDateRange(0, 1);
        var requestedRange = GetVisibleDateRange(requestedStart, requestedEnd, includeAdjacentPoints: true);
        if (!fullRange.HasValue || !requestedRange.HasValue)
        {
            return;
        }

        if (requestedRange.Value.FromUtc.Date <= fullRange.Value.FromUtc.Date &&
            requestedRange.Value.ToUtc.Date >= fullRange.Value.ToUtc.Date)
        {
            return;
        }

        await ViewportRefinementRequested.InvokeAsync(new EloChartViewportRange(
            DateTime.SpecifyKind(requestedRange.Value.FromUtc, DateTimeKind.Utc),
            DateTime.SpecifyKind(requestedRange.Value.ToUtc, DateTimeKind.Utc)));
    }

    private (DateTime FromUtc, DateTime ToUtc)? GetVisibleDateRange(
        double requestedStart,
        double requestedEnd,
        bool includeAdjacentPoints = false)
    {
        var dates = samplingMode == EloChartSamplingMode.GameByGame
            ? activeDates
            : allPoints
                .Select(x => x.GameDateTimeUtc)
                .Distinct()
                .OrderBy(x => x)
                .ToList();
        if (dates.Count == 0)
        {
            return null;
        }

        var startFraction = Math.Clamp(Math.Min(requestedStart, requestedEnd), 0, 1);
        var endFraction = Math.Clamp(Math.Max(requestedStart, requestedEnd), 0, 1);
        var startIndex = (int)Math.Floor(startFraction * (dates.Count - 1));
        var endIndex = (int)Math.Ceiling(endFraction * (dates.Count - 1));
        if (includeAdjacentPoints)
        {
            startIndex = Math.Max(0, startIndex - 1);
            endIndex = Math.Min(dates.Count - 1, endIndex + 1);
        }

        return (dates[startIndex], dates[endIndex]);
    }

    private void ResetView()
    {
        chartZoom = 100;
        viewStart = 0;
        viewEnd = 1;
    }

    private string SamplingButtonClass(EloChartSamplingMode mode)
        => samplingMode == mode
            ? "btn btn-sm btn-primary"
            : "btn btn-sm btn-outline-secondary";

    private static IReadOnlyList<EloChartPoint> SamplePoints(
        IReadOnlyList<EloChartPoint> sourcePoints,
        EloChartSamplingMode mode)
    {
        if (mode == EloChartSamplingMode.GameByGame || sourcePoints.Count < 2)
        {
            return sourcePoints;
        }

        var points = sourcePoints.OrderBy(point => point.GameDateTimeUtc).ToList();
        var firstBoundary = mode == EloChartSamplingMode.Weekly
            ? EndOfIsoWeek(points[0].GameDateTimeUtc)
            : EndOfMonth(points[0].GameDateTimeUtc);
        var lastPointDate = points[^1].GameDateTimeUtc;
        var sampled = new List<EloChartPoint>();
        var cursor = firstBoundary;
        var latestPointIndex = -1;
        EloChartPoint? latestPoint = null;

        while (cursor <= lastPointDate)
        {
            while (latestPointIndex + 1 < points.Count && points[latestPointIndex + 1].GameDateTimeUtc <= cursor)
            {
                latestPointIndex += 1;
                latestPoint = points[latestPointIndex];
            }

            if (latestPoint is not null)
            {
                sampled.Add(latestPoint with { GameDateTimeUtc = cursor });
            }

            cursor = mode == EloChartSamplingMode.Weekly
                ? cursor.AddDays(7)
                : EndOfMonth(cursor.AddTicks(1));
        }

        if (sampled.Count == 0 || sampled[^1].GameDateTimeUtc < lastPointDate)
        {
            sampled.Add(points[^1]);
        }

        return sampled;
    }

    private static DateTime EndOfIsoWeek(DateTime value)
    {
        var utcDate = DateTime.SpecifyKind(value.Date, DateTimeKind.Utc);
        var daysUntilSunday = ((int)DayOfWeek.Sunday - (int)utcDate.DayOfWeek + 7) % 7;
        return utcDate.AddDays(daysUntilSunday + 1).AddTicks(-1);
    }

    private static DateTime EndOfMonth(DateTime value)
    {
        var utcDate = DateTime.SpecifyKind(value.Date, DateTimeKind.Utc);
        return new DateTime(utcDate.Year, utcDate.Month, 1, 0, 0, 0, DateTimeKind.Utc)
            .AddMonths(1)
            .AddTicks(-1);
    }

    private static string SamplingLabel(EloChartSamplingMode mode)
        => mode switch
        {
            EloChartSamplingMode.Weekly => "Weekly snapshots",
            EloChartSamplingMode.Monthly => "Monthly snapshots",
            _ => "Game snapshots"
        };

    private static string FormatDate(DateTime value)
        => value.ToLocalTime().ToString("MMM d, yyyy", CultureInfo.CurrentCulture);

    private string FormatCategoryAxis(object value)
    {
        if (samplingMode == EloChartSamplingMode.GameByGame &&
            value is IConvertible convertible &&
            activeDates.Count > 0)
        {
            try
            {
                var index = (int)Math.Round(convertible.ToDouble(CultureInfo.InvariantCulture));
                if (index < 0 || index >= activeDates.Count)
                {
                    return string.Empty;
                }

                return activeDates[index].ToLocalTime().ToString("MMM yyyy", CultureInfo.CurrentCulture);
            }
            catch (FormatException)
            {
            }
            catch (InvalidCastException)
            {
            }
            catch (OverflowException)
            {
            }
        }

        return value is DateTime date
            ? date.ToLocalTime().ToString("MMM yyyy", CultureInfo.CurrentCulture)
            : value?.ToString() ?? string.Empty;
    }

    private static string FormatMovement(decimal value)
        => value switch
        {
            > 0 => $"+{value:0}",
            < 0 => value.ToString("0"),
            _ => "0"
        };

    private static string FormatEloAxis(object value)
        => value is IFormattable formattable
            ? formattable.ToString("0", CultureInfo.CurrentCulture)
            : value?.ToString() ?? string.Empty;
}
