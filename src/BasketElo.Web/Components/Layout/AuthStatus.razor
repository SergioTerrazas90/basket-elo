@using System.Security.Claims
@using BasketElo.Infrastructure.Identity
@using Microsoft.Extensions.Options
@inject IOptions<AuthOptions> AuthOptions

@if (AuthOptions.Value.Enabled)
{
    <AuthorizeView>
        <Authorized>
            <div class="auth-status">
                <span>@DisplayName(context.User)</span>
                <a href="auth/logout">Sign out</a>
            </div>
        </Authorized>
        <NotAuthorized>
            <a class="auth-sign-in" href="auth/login">Sign in</a>
        </NotAuthorized>
    </AuthorizeView>
}
else
{
    <AuthorizeView>
        <Authorized>
            <div class="dev-persona-switch">
                <label for="devPersona">Testing as</label>
                <select id="devPersona" class="dev-persona-select" onchange="window.location.href='/dev/persona?persona=' + encodeURIComponent(this.value) + '&returnUrl=' + encodeURIComponent(window.location.pathname + window.location.search)">
                    @foreach (var persona in Personas)
                    {
                        <option value="@persona.Key" selected="@(persona.Key == CurrentPersona(context.User))">@persona.Label</option>
                    }
                </select>
            </div>
        </Authorized>
        <NotAuthorized>
            <div class="dev-persona-switch">
                <label for="devPersona">Testing as</label>
                <select id="devPersona" class="dev-persona-select" onchange="window.location.href='/dev/persona?persona=' + encodeURIComponent(this.value) + '&returnUrl=' + encodeURIComponent(window.location.pathname + window.location.search)">
                    @foreach (var persona in Personas)
                    {
                        <option value="@persona.Key" selected="@(persona.Key == "anonymous")">@persona.Label</option>
                    }
                </select>
            </div>
        </NotAuthorized>
    </AuthorizeView>
}

@code {
    private static string DisplayName(ClaimsPrincipal user)
        => user.FindFirstValue(ClaimTypes.Name)
            ?? user.FindFirstValue(ClaimTypes.Email)
            ?? "Signed in";

    private static string CurrentPersona(ClaimsPrincipal user)
    {
        var email = user.FindFirstValue(ClaimTypes.Email);
        if (string.Equals(email, "dev-free@basket-elo.local", StringComparison.OrdinalIgnoreCase))
        {
            return "free";
        }

        if (string.Equals(email, "dev-paid@basket-elo.local", StringComparison.OrdinalIgnoreCase))
        {
            return "paid";
        }

        return user.IsInRole("admin") ? "admin" : "anonymous";
    }

    private static readonly IReadOnlyCollection<PersonaOption> Personas =
    [
        new("anonymous", "Anonymous"),
        new("free", "Free"),
        new("paid", "Paying"),
        new("admin", "Admin")
    ];

    private sealed record PersonaOption(string Key, string Label);
}
