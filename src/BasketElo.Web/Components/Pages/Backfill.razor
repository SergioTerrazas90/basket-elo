@page "/backfill"
@attribute [Authorize(Roles = "admin")]
@rendermode InteractiveServer
@using BasketElo.Domain.Backfill
@inject HttpClient Http

<PageTitle>Backfill Coverage</PageTitle>

<div class="backfill-page">
    <section class="page-header">
        <div>
            <p class="eyebrow">Coverage Dashboard</p>
            <h1>League and season backfill coverage</h1>
            <p class="intro">See what is already loaded, spot gaps across configured history, and queue one season or a full league from the same screen.</p>
        </div>
        <button class="btn btn-outline-primary" @onclick="RefreshAsync" disabled="@isBusy">Refresh</button>
    </section>

    @if (!string.IsNullOrWhiteSpace(feedbackMessage))
    {
        <div class="alert @(feedbackIsError ? "alert-danger" : "alert-success")" role="alert">
            @feedbackMessage
        </div>
    }

    <section class="filters-panel">
        <div class="filter-field">
            <label for="countryFilter">Country</label>
            <select id="countryFilter" class="form-select" @bind="selectedCountry">
                <option value="">All</option>
                @foreach (var country in CountryOptions)
                {
                    <option value="@country">@country</option>
                }
            </select>
        </div>

        <div class="filter-field">
            <label for="leagueFilter">League</label>
            <select id="leagueFilter" class="form-select" @bind="selectedLeague">
                <option value="">All</option>
                @foreach (var league in LeagueOptions)
                {
                    <option value="@league">@league</option>
                }
            </select>
        </div>

        <div class="filter-field">
            <label for="statusFilter">Status</label>
            <select id="statusFilter" class="form-select" @bind="selectedStatus">
                <option value="">All</option>
                @foreach (var status in StatusOptions)
                {
                    <option value="@status">@status</option>
                }
            </select>
        </div>

        <div class="filter-field">
            <label for="inspectionFilter">Inspection</label>
            <select id="inspectionFilter" class="form-select" @bind="selectedInspection">
                @foreach (var option in InspectionOptions)
                {
                    <option value="@option.Value">@option.Label</option>
                }
            </select>
        </div>

        <div class="filter-field compact-toggle">
            <label for="dryRunToggle">Dry Run</label>
            <input id="dryRunToggle" class="form-check-input" type="checkbox" @bind="dryRun" />
        </div>

        <div class="filter-field compact-input">
            <label for="maxRequestsInput">Max Requests</label>
            <input id="maxRequestsInput" class="form-control" type="number" min="1" max="100" @bind="maxRequests" />
        </div>
    </section>

    @if (isBusy && rows.Count == 0)
    {
        <p>Loading coverage...</p>
    }
    else
    {
        <section class="summary-panel">
            <div class="summary-card">
                <span class="summary-label">Configured Leagues</span>
                <strong>@LeagueSummaries.Count</strong>
            </div>
            <div class="summary-card">
                <span class="summary-label">Configured Seasons</span>
                <strong>@FilteredRows.Count</strong>
            </div>
            <div class="summary-card">
                <span class="summary-label">Completed</span>
                <strong>@FilteredRows.Count(x => x.CoverageStatus == "completed")</strong>
            </div>
            <div class="summary-card">
                <span class="summary-label">Missing</span>
                <strong>@FilteredRows.Count(x => x.CoverageStatus == "not_started")</strong>
            </div>
            <div class="summary-card inspection-card">
                <span class="summary-label">Needs Inspection</span>
                <strong>@FilteredRows.Count(x => x.NeedsInspection)</strong>
            </div>
            <div class="summary-card reviewed-card">
                <span class="summary-label">Reviewed Flags</span>
                <strong>@FilteredRows.Count(x => !string.IsNullOrWhiteSpace(x.InspectionStatus))</strong>
            </div>
        </section>

        <section class="range-panel" aria-labelledby="range-import-heading">
            <div class="section-head">
                <h2 id="range-import-heading">Range import</h2>
            </div>
            <div class="range-controls">
                <div class="filter-field range-league-field">
                    <label for="rangeLeague">League</label>
                    <select id="rangeLeague" class="form-select" @bind="selectedRangeLeagueKey" @bind:after="RangeLeagueChanged">
                        @foreach (var league in AllLeagueSummaries)
                        {
                            <option value="@LeagueKey(league)">@league.DisplayName</option>
                        }
                    </select>
                </div>
                <div class="filter-field">
                    <label for="rangeStartSeason">Start season</label>
                    <input id="rangeStartSeason" class="form-control" inputmode="numeric" placeholder="1946-1947" @bind="rangeStartSeason" @bind:event="oninput" />
                </div>
                <div class="filter-field">
                    <label for="rangeEndSeason">End season</label>
                    <input id="rangeEndSeason" class="form-control" inputmode="numeric" placeholder="1959-1960" @bind="rangeEndSeason" @bind:event="oninput" />
                </div>
                <div class="filter-field">
                    <label for="rangeDataMode">Data mode</label>
                    <select id="rangeDataMode" class="form-select" @bind="rangeDataMode">
                        <option value="missing">Missing only</option>
                        <option value="replace">Refresh existing</option>
                    </select>
                </div>
                <div class="filter-field">
                    <label for="rangeOrder">Queue order</label>
                    <select id="rangeOrder" class="form-select" @bind="rangeNewestFirst">
                        <option value="true">Newest first</option>
                        <option value="false">Oldest first</option>
                    </select>
                </div>
                <button class="btn btn-primary range-submit"
                        type="button"
                        @onclick="TriggerRangeAsync"
                        disabled="@(isBusy || !CanSubmitRange)">
                    Queue range
                </button>
            </div>
            @if (!string.IsNullOrWhiteSpace(RangeValidationError))
            {
                <p class="range-validation" role="alert">@RangeValidationError</p>
            }
        </section>

        @if (ReviewedRows.Count > 0)
        {
            <section class="reviewed-summary-panel" aria-label="Reviewed inspection summary">
                @foreach (var item in ReviewedStatusSummaries)
                {
                    <button class="reviewed-summary-chip @(selectedInspection == item.Status ? "selected" : null)"
                            type="button"
                            @onclick="() => selectedInspection = item.Status">
                        <span>@FormatInspectionStatus(item.Status)</span>
                        <strong>@item.Count</strong>
                    </button>
                }
            </section>
        }

        <section class="table-section">
            <div class="section-head">
                <h2>League overview</h2>
                <p>Queue every configured season for a league in one click.</p>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle coverage-table">
                    <thead>
                        <tr>
                            <th>Country</th>
                            <th>League</th>
                            <th>Seasons</th>
                            <th>Completed</th>
                            <th>Warnings</th>
                            <th>Inspect</th>
                            <th>Latest Run</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var league in LeagueSummaries)
                        {
                            <tr>
                                <td>@league.Country</td>
                                <td>@league.DisplayName</td>
                                <td>@league.TotalSeasons</td>
                                <td>@league.CompletedSeasons</td>
                                <td>@league.WarningSeasons</td>
                                <td>@league.InspectionSeasons</td>
                                <td>@FormatDate(league.LastRunUtc)</td>
                                <td>
                                    <button class="btn btn-sm btn-outline-primary"
                                            @onclick="() => TriggerLeagueAsync(league)"
                                            disabled="@isBusy">
                                        Trigger league
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="table-section">
            <div class="section-head">
                <h2>Season coverage</h2>
                <p>Scan the latest status per season and trigger a single season when needed.</p>
            </div>

            <div class="table-responsive">
                <table class="table table-striped align-middle coverage-table">
                    <thead>
                        <tr>
                            <th>Country</th>
                            <th>League</th>
                            <th>Season</th>
                            <th>Status</th>
                            <th>Last Run</th>
                            <th>Requests</th>
                            <th>Warnings</th>
                            <th>Inspect</th>
                            <th>Data</th>
                            <th>Games</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in FilteredRows)
                        {
                            <tr class="@RowClass(row)">
                                <td>@NormalizeCountry(row.Country)</td>
                                <td>@row.DisplayName</td>
                                <td>@row.Season</td>
                                <td><span class="status-pill @StatusClass(row.CoverageStatus)">@FormatStatus(row.CoverageStatus)</span></td>
                                <td>@FormatDate(row.LastRunUtc)</td>
                                <td>@row.RequestsUsed</td>
                                <td>
                                    @if (row.Warnings.Count == 0)
                                    {
                                        <span>@row.WarningCount</span>
                                    }
                                    else
                                    {
                                        <details class="warning-details">
                                            <summary>@row.WarningCount warning@(row.WarningCount == 1 ? string.Empty : "s")</summary>
                                            <ul>
                                                @foreach (var warning in row.Warnings)
                                                {
                                                    <li>@warning</li>
                                                }
                                            </ul>
                                        </details>
                                    }
                                </td>
                                <td>
                                    @if (row.NeedsInspection)
                                    {
                                        <details class="inspection-details">
                                            <summary>@FormatInspectionSeverity(row.InspectionSeverity)</summary>
                                            <ul>
                                                @foreach (var reason in row.InspectionReasons)
                                                {
                                                    <li>@reason</li>
                                                }
                                            </ul>
                                            <div class="inspection-actions">
                                                <button class="btn btn-sm btn-outline-danger"
                                                        @onclick='() => SaveInspectionDecisionAsync(row, "covid_partial_missing")'
                                                        disabled="@isBusy">
                                                    COVID gap
                                                </button>
                                                <button class="btn btn-sm btn-outline-warning"
                                                        @onclick='() => SaveInspectionDecisionAsync(row, "provider_gap")'
                                                        disabled="@isBusy">
                                                    Provider gap
                                                </button>
                                                <button class="btn btn-sm btn-outline-secondary"
                                                        @onclick='() => SaveInspectionDecisionAsync(row, "confirmed_empty")'
                                                        disabled="@isBusy">
                                                    Empty
                                                </button>
                                                <button class="btn btn-sm btn-outline-success"
                                                        @onclick='() => SaveInspectionDecisionAsync(row, "resolved")'
                                                        disabled="@isBusy">
                                                    Resolved
                                                </button>
                                            </div>
                                        </details>
                                    }
                                    else if (!string.IsNullOrWhiteSpace(row.InspectionStatus))
                                    {
                                        <details class="inspection-details reviewed-details">
                                            <summary>@FormatInspectionStatus(row.InspectionStatus)</summary>
                                            @if (!string.IsNullOrWhiteSpace(row.InspectionNote))
                                            {
                                                <p>@row.InspectionNote</p>
                                            }
                                            <span class="reviewed-date">@FormatDate(row.InspectionReviewedAtUtc)</span>
                                        </details>
                                    }
                                    else
                                    {
                                        <span class="muted-cell">-</span>
                                    }
                                </td>
                                <td>@(row.DataPresent ? "Yes" : "No")</td>
                                <td>@row.GameCount</td>
                                <td>
                                    <button class="btn btn-sm btn-primary"
                                            @onclick="() => TriggerSeasonAsync(row)"
                                            disabled="@isBusy">
                                        Trigger season
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }
</div>

@code {
    private readonly List<BackfillCoverageRow> rows = [];
    private bool dryRun = true;
    private int maxRequests = 2;
    private bool isBusy;
    private string? feedbackMessage;
    private bool feedbackIsError;
    private string? selectedCountry;
    private string? selectedLeague;
    private string? selectedStatus;
    private string selectedInspection = string.Empty;
    private string selectedRangeLeagueKey = string.Empty;
    private string rangeStartSeason = string.Empty;
    private string rangeEndSeason = string.Empty;
    private string rangeDataMode = "missing";
    private string rangeNewestFirst = "true";

    private IReadOnlyCollection<string> CountryOptions => rows.Select(x => NormalizeCountry(x.Country)).Distinct().OrderBy(x => x).ToList();
    private IReadOnlyCollection<string> LeagueOptions => rows.Select(x => x.DisplayName).Distinct().OrderBy(x => x).ToList();
    private static IReadOnlyCollection<string> StatusOptions => ["not_started", "in_progress", "completed", "completed_with_warnings", "dry_run", "no_data", "failed", "partial"];
    private static IReadOnlyCollection<InspectionFilterOption> InspectionOptions =>
    [
        new(string.Empty, "All"),
        new("active", "Needs inspection"),
        new("reviewed", "Reviewed"),
        new("provider_gap", "Provider gap"),
        new("covid_partial_missing", "COVID partial missing"),
        new("confirmed_empty", "Confirmed empty"),
        new("resolved", "Resolved"),
        new("clean", "No inspection state")
    ];

    private IReadOnlyCollection<BackfillCoverageRow> FilteredRows => rows
        .Where(x => string.IsNullOrWhiteSpace(selectedCountry) || NormalizeCountry(x.Country) == selectedCountry)
        .Where(x => string.IsNullOrWhiteSpace(selectedLeague) || x.DisplayName == selectedLeague)
        .Where(x => string.IsNullOrWhiteSpace(selectedStatus) || x.CoverageStatus == selectedStatus)
        .Where(MatchesInspectionFilter)
        .ToList();

    private IReadOnlyCollection<BackfillCoverageRow> ReviewedRows => rows
        .Where(x => !string.IsNullOrWhiteSpace(x.InspectionStatus))
        .ToList();

    private IReadOnlyCollection<ReviewedStatusSummary> ReviewedStatusSummaries => ReviewedRows
        .GroupBy(x => x.InspectionStatus!)
        .Select(group => new ReviewedStatusSummary(group.Key, group.Count()))
        .OrderByDescending(x => x.Count)
        .ThenBy(x => FormatInspectionStatus(x.Status))
        .ToList();

    private IReadOnlyCollection<LeagueSummary> AllLeagueSummaries => SummarizeLeagues(rows);

    private IReadOnlyCollection<LeagueSummary> LeagueSummaries => SummarizeLeagues(FilteredRows);

    private static IReadOnlyCollection<LeagueSummary> SummarizeLeagues(IEnumerable<BackfillCoverageRow> source) => source
        .GroupBy(x => x.DisplayName)
        .Select(group => new LeagueSummary(
            DisplayCountry(group.Key, group.Select(x => x.Country)),
            group.Key,
            group.Select(x => x.Season).Distinct(StringComparer.OrdinalIgnoreCase).Count(),
            group.GroupBy(x => x.Season).Count(season => season.Any(x => x.CoverageStatus == "completed")),
            group.GroupBy(x => x.Season).Count(season => season.Any(x => x.CoverageStatus == "completed_with_warnings")),
            group.GroupBy(x => x.Season).Count(season => season.Any(x => x.NeedsInspection)),
            group.Max(x => x.LastRunUtc),
            group.MinBy(x => SeasonStartYear(x.Season))!.Season,
            group.MaxBy(x => SeasonStartYear(x.Season))!.Season))
        .OrderBy(x => x.Country)
        .ThenBy(x => x.DisplayName)
        .ToList();

    private string? RangeValidationError
    {
        get
        {
            if (SelectedRangeLeague is null)
            {
                return "Select a configured league.";
            }

            if (!TryGetSeasonStartYear(rangeStartSeason, out var startYear) ||
                !TryGetSeasonStartYear(rangeEndSeason, out var endYear))
            {
                return "Use full consecutive-year labels such as 1946-1947.";
            }

            return startYear > endYear ? "Start season must not be after end season." : null;
        }
    }

    private LeagueSummary? SelectedRangeLeague =>
        AllLeagueSummaries.FirstOrDefault(x => LeagueKey(x) == selectedRangeLeagueKey);

    private bool CanSubmitRange => RangeValidationError is null;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    private Task RefreshAsync() => RefreshAsync(preserveFeedback: false);

    private async Task RefreshAsync(bool preserveFeedback)
    {
        isBusy = true;
        if (!preserveFeedback)
        {
            feedbackMessage = null;
        }

        try
        {
            var response = await Http.GetFromJsonAsync<BackfillCoverageResponse>("api/backfill/coverage");
            rows.Clear();
            if (response is not null)
            {
                rows.AddRange(response.Rows);
            }

            if (SelectedRangeLeague is null)
            {
                var defaultLeague = AllLeagueSummaries.FirstOrDefault(x => x.DisplayName == "United States: NBA") ??
                    AllLeagueSummaries.FirstOrDefault();
                if (defaultLeague is not null)
                {
                    selectedRangeLeagueKey = LeagueKey(defaultLeague);
                    RangeLeagueChanged();
                }
            }
        }
        catch (Exception ex)
        {
            feedbackIsError = true;
            feedbackMessage = $"Could not load coverage: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task TriggerSeasonAsync(BackfillCoverageRow row)
    {
        await SubmitAsync(
            "api/backfill/jobs",
            new CreateBackfillJobRequest
            {
                Provider = row.Provider,
                Country = row.Country,
                LeagueName = row.LeagueName,
                Season = row.Season,
                DryRun = dryRun,
                MaxRequests = maxRequests
            },
            $"Queued {row.DisplayName} {row.Season}.");
    }

    private async Task TriggerLeagueAsync(LeagueSummary league)
    {
        await SubmitAsync(
            "api/backfill/leagues/jobs",
            new TriggerLeagueBackfillRequest
            {
                DisplayName = league.DisplayName,
                DryRun = dryRun,
                MaxRequests = maxRequests
            },
            $"Queued configured seasons for {league.DisplayName}.");
    }

    private async Task TriggerRangeAsync()
    {
        var league = SelectedRangeLeague;
        if (league is null || RangeValidationError is not null)
        {
            feedbackIsError = true;
            feedbackMessage = RangeValidationError ?? "Select a configured league.";
            return;
        }

        isBusy = true;
        feedbackMessage = null;
        try
        {
            var response = await Http.PostAsJsonAsync(
                "api/backfill/leagues/range/jobs",
                new TriggerLeagueRangeBackfillRequest
                {
                    DisplayName = league.DisplayName,
                    StartSeason = rangeStartSeason,
                    EndSeason = rangeEndSeason,
                    OnlyMissing = rangeDataMode == "missing",
                    ReplaceExisting = rangeDataMode == "replace",
                    NewestFirst = rangeNewestFirst == "true",
                    DryRun = dryRun,
                    MaxRequests = maxRequests
                });
            if (!response.IsSuccessStatusCode)
            {
                var body = await response.Content.ReadAsStringAsync();
                throw new InvalidOperationException(string.IsNullOrWhiteSpace(body) ? response.ReasonPhrase : body);
            }

            var result = await response.Content.ReadFromJsonAsync<QueueBackfillJobsResponse>();
            feedbackIsError = false;
            feedbackMessage = result is null
                ? $"Queued {league.DisplayName} range."
                : $"Queued {result.QueuedJobs} of {result.RequestedSeasons} seasons for {league.DisplayName}; " +
                  $"skipped {result.SkippedActiveJobs} active and {result.SkippedExistingSeasons} existing.";
            await RefreshAsync(preserveFeedback: true);
        }
        catch (Exception ex)
        {
            feedbackIsError = true;
            feedbackMessage = $"Action failed: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task SaveInspectionDecisionAsync(BackfillCoverageRow row, string status)
    {
        var note = status switch
        {
            "covid_partial_missing" => "Reviewed: games were likely played before a COVID cancellation/suspension, but API-Sports returned no games.",
            "provider_gap" => "Reviewed: provider data appears incomplete or unavailable for this season.",
            "confirmed_empty" => "Reviewed: no games are expected for this configured season.",
            "resolved" => "Reviewed: issue resolved or accepted after inspection.",
            _ => "Reviewed."
        };

        await SubmitAsync(
            "api/backfill/coverage/decisions",
            new SaveBackfillInspectionDecisionRequest
            {
                Provider = row.Provider,
                Country = row.Country,
                LeagueName = row.LeagueName,
                Season = row.Season,
                Status = status,
                Note = note,
                ReviewedBy = "codex"
            },
            $"Marked {row.DisplayName} {row.Season} as {FormatInspectionStatus(status)}.");
    }

    private async Task SubmitAsync<TRequest>(string url, TRequest request, string successMessage)
    {
        isBusy = true;
        feedbackMessage = null;

        try
        {
            var response = await Http.PostAsJsonAsync(url, request);
            if (!response.IsSuccessStatusCode)
            {
                var body = await response.Content.ReadAsStringAsync();
                throw new InvalidOperationException(string.IsNullOrWhiteSpace(body) ? response.ReasonPhrase : body);
            }

            feedbackIsError = false;
            feedbackMessage = successMessage;
            await RefreshAsync(preserveFeedback: true);
        }
        catch (Exception ex)
        {
            feedbackIsError = true;
            feedbackMessage = $"Action failed: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }

    private static string FormatStatus(string status) => status switch
    {
        "dry_run" => "dry run",
        "no_data" => "no data",
        "partial" => "partial data",
        _ => status.Replace('_', ' ')
    };

    private static string FormatDate(DateTime? value) => value?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "-";

    private static string StatusClass(string status) => status switch
    {
        "completed" => "status-completed",
        "completed_with_warnings" => "status-warning",
        "dry_run" => "status-dry-run",
        "no_data" => "status-empty",
        "failed" => "status-failed",
        "in_progress" => "status-progress",
        "partial" => "status-partial",
        _ => "status-empty"
    };

    private static string RowClass(BackfillCoverageRow row)
    {
        if (row.NeedsInspection)
        {
            return row.InspectionSeverity == "high" ? "inspection-row inspection-row-high" : "inspection-row";
        }

        return !string.IsNullOrWhiteSpace(row.InspectionStatus) ? "reviewed-row" : string.Empty;
    }

    private void RangeLeagueChanged()
    {
        var league = SelectedRangeLeague;
        if (league is null)
        {
            return;
        }

        rangeStartSeason = league.FirstSeason;
        rangeEndSeason = league.LastSeason;
    }

    private static string LeagueKey(LeagueSummary league) => league.DisplayName;

    private static int SeasonStartYear(string season) =>
        TryGetSeasonStartYear(season, out var year) ? year : int.MaxValue;

    private static string NormalizeCountry(string country) =>
        string.Equals(country, "USA", StringComparison.OrdinalIgnoreCase) ? "United States" : country;

    private static string DisplayCountry(string displayName, IEnumerable<string> countries)
    {
        var separator = displayName.IndexOf(':');
        return separator > 0
            ? displayName[..separator].Trim()
            : NormalizeCountry(countries.First());
    }

    private static bool TryGetSeasonStartYear(string season, out int startYear)
    {
        startYear = default;
        var pieces = season.Split('-', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries);
        return pieces.Length == 2 &&
            int.TryParse(pieces[0], out startYear) &&
            int.TryParse(pieces[1], out var endYear) &&
            startYear >= 1900 &&
            endYear == startYear + 1;
    }

    private bool MatchesInspectionFilter(BackfillCoverageRow row)
    {
        return selectedInspection switch
        {
            "" => true,
            "active" => row.NeedsInspection,
            "reviewed" => !string.IsNullOrWhiteSpace(row.InspectionStatus),
            "clean" => !row.NeedsInspection && string.IsNullOrWhiteSpace(row.InspectionStatus),
            _ => string.Equals(row.InspectionStatus, selectedInspection, StringComparison.OrdinalIgnoreCase)
        };
    }

    private static string FormatInspectionSeverity(string severity) => severity switch
    {
        "high" => "High",
        "medium" => "Review",
        "reviewed" => "Reviewed",
        _ => "Review"
    };

    private static string FormatInspectionStatus(string? status) => status switch
    {
        "confirmed_empty" => "Confirmed empty",
        "provider_gap" => "Provider gap",
        "covid_partial_missing" => "COVID partial missing",
        "resolved" => "Resolved",
        _ => status?.Replace('_', ' ') ?? "Reviewed"
    };

    private sealed record LeagueSummary(
        string Country,
        string DisplayName,
        int TotalSeasons,
        int CompletedSeasons,
        int WarningSeasons,
        int InspectionSeasons,
        DateTime? LastRunUtc,
        string FirstSeason,
        string LastSeason);

    private sealed record InspectionFilterOption(string Value, string Label);

    private sealed record ReviewedStatusSummary(string Status, int Count);
}
